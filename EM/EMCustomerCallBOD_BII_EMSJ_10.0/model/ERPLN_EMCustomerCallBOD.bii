    <isIdentifier>false</isIdentifier>
    <isMandatory>false</isMandatory>
    <isReadOnly>false</isReadOnly>
    <onGetHookExpression>&#x9;if not isspace(i.ERPCall) then&#xD;&#xA;&#x9;&#x9;if i.CustomerCallHeader_BODRouter &lt;> 5 then&#xD;&#xA;&#x9;&#x9;&#x9;ret = tsclm.dll9003.append.all.transaction.text(i.ERPCall,TRUE, o.CustomerCallHeader_ProblemComment)&#xD;&#xA;&#x9;&#x9;&#x9;if ret &lt; 0 then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;dal.set.error.message(&quot;@ Error in Problem Comment Text Field&quot;)&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;return(DALHOOKERROR)&#xD;&#xA;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;else&#xD;&#xA;&#x9;&#x9;&#x9;if i.CustomerCallHeader_BODRouter = 5 then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;ret = tsbod.dll9001c.get.all.text.from.history(i.ERPCall, o.CustomerCallHeader_ProblemComment) &#xD;&#xA;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;endif&#x9;&#xD;&#xA;&#x9;endif&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;return(0)</onGetHookExpression>
    <AttributeImplementationRelationship id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_ProblemComment-relERPCall">
      <position>1</position>
      <componentImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall">EMCustomerCallBOD</componentImplementation>
      <attributeImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall-attrERPCall">ERPCall</attributeImplementation>
    </AttributeImplementationRelationship>
    <AttributeImplementationRelationship id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_ProblemComment-relCustomerCallHeader_BODRouter">
      <position>2</position>
      <componentImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall">EMCustomerCallBOD</componentImplementation>
      <attributeImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_BODRouter">CustomerCallHeader_BODRouter</attributeImplementation>
    </AttributeImplementationRelationship>
  </AttributeImplementation>
