  <AttributeImplementation id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_Status_Code">
    <name>CustomerCallHeader_Status_Code</name>
    <attribute idref="EMCustomerCallBOD_BID.bi#bidEMCustomerCall0-compEMCustomerCall-attrCustomerCallHeader_Status_Code">CustomerCallHeader_Status_Code</attribute>
    <type>calculated</type>
    <datatype idref="associations_lib.bi#bdttcmcs.str25">tcmcs.str25</datatype>
    <isIdentifier>false</isIdentifier>
    <isMandatory>false</isMandatory>
    <isReadOnly>false</isReadOnly>
    <onGetHookExpression>if tcbod.dll0038.object.being.deleted() and&#xD;&#xA;&#x9;   i.ERPStatus &lt;> tsclm.stat.accept then&#xD;&#xA;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_DELETED&#xD;&#xA;&#x9;else&#xD;&#xA;&#x9;&#x9;if i.ERPBlocked = tcyesno.yes then&#xD;&#xA;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_HOLD&#xD;&#xA;&#x9;&#x9;else&#xD;&#xA;&#x9;&#x9;&#x9;on case i.ERPStatus&#xD;&#xA;&#x9;&#x9;&#x9;case tsclm.stat.regist:&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_OPEN&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;break&#xD;&#xA;&#x9;&#x9;&#x9;case tsclm.stat.assign:&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_ASSIGNED&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;break&#xD;&#xA;&#x9;&#x9;&#x9;case tsclm.stat.process:&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_INPROCESS&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;break&#xD;&#xA;&#x9;&#x9;&#x9;case tsclm.stat.transf:&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_TRANSFERRED&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;break&#xD;&#xA;&#x9;&#x9;&#x9;case tsclm.stat.solved:&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_SOLVED&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;break&#xD;&#xA;&#x9;&#x9;&#x9;case tsclm.stat.accept:&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_Code = STATUS_ACCEPTED&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;break&#xD;&#xA;&#x9;&#x9;&#x9;endcase&#xD;&#xA;&#x9;&#x9;endif&#xD;&#xA;&#x9;endif&#xD;&#xA;&#xD;&#xA;&#x9;return(0)&#xD;&#xA;&#x9;&#x9;</onGetHookExpression>
    <AttributeImplementationRelationship id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_Status_Code-relERPBlocked">
      <position>1</position>
      <componentImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall">EMCustomerCallBOD</componentImplementation>
