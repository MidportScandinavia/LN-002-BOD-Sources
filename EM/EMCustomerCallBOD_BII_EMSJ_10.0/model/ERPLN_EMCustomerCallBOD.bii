  <AttributeImplementation id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_CauseCodeSearchArgument">
    <name>CustomerCallHeader_CauseCodeSearchArgument</name>
    <attribute idref="EMCustomerCallBOD_BID.bi#bidEMCustomerCall0-compEMCustomerCall-attrCustomerCallHeader_CauseCodeSearchArgument">CustomerCallHeader_CauseCodeSearchArgument</attribute>
    <type>calculated</type>
    <datatype idref="associations_lib.bi#bdttcmcs.str100m">tcmcs.str100m</datatype>
    <isIdentifier>false</isIdentifier>
    <isMandatory>false</isMandatory>
    <isReadOnly>false</isReadOnly>
    <onGetHookExpression>&#x9;domain&#x9;tsclm.cprl check.cprl&#xD;&#xA;&#x9;domain&#x9;tscfg.sigr sigr&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;o.CustomerCallHeader_CauseCodeSearchArgument = &quot;&quot;&#xD;&#xA;&#x9;if not isspace(i.CustomerCallHeader_CauseCode) then&#xD;&#xA;&#x9;&#x9;|* Fetch Sigr&#xD;&#xA;&#x9;&#x9;txcom.dll9002.get.serialized.item.group(i.CustomerCallHeader_Item, i.CustomerCallHeader_SerialNumber, sigr)&#xD;&#xA;&#x9;&#x9;check.cprl = &quot;9999999999&quot;&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;select&#x9;tsclm902.*&#xD;&#xA;&#x9;&#x9;from&#x9;tsclm902&#xD;&#xA;&#x9;&#x9;where&#x9;tsclm902.sigr = {:sigr}&#xD;&#xA;&#x9;&#x9;and&#x9;(tsclm902.cprl = {:i.ERPReportedProblem}&#xD;&#xA;&#x9;&#x9;or&#x9;tsclm902.cprl = {:check.cprl} &#xD;&#xA;&#x9;&#x9;or&#x9;tsclm902.cprl = &quot;&quot;)&#xD;&#xA;&#x9;&#x9;and&#x9;tsclm902.conc.c = {:i.CustomerCallHeader_CauseCode}&#xD;&#xA;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;o.CustomerCallHeader_CauseCodeSearchArgument = tsclm902.cocn.c&#xD;&#xA;&#x9;&#x9;&#x9;io.CustomerCallHeader_CauseCodeSearchArgument.isSet = true&#xD;&#xA;&#x9;&#x9;endselect&#xD;&#xA;&#x9;endif&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;return(0)</onGetHookExpression>
    <AttributeImplementationRelationship id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_CauseCodeSearchArgument-relCustomerCallHeader_CauseCode">
      <position>1</position>
      <componentImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall">EMCustomerCallBOD</componentImplementation>
      <attributeImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_CauseCode">CustomerCallHeader_CauseCode</attributeImplementation>
    </AttributeImplementationRelationship>
    <AttributeImplementationRelationship id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_CauseCodeSearchArgument-relCustomerCallHeader_Item">
      <position>2</position>
      <componentImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall">EMCustomerCallBOD</componentImplementation>
      <attributeImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_Item">CustomerCallHeader_Item</attributeImplementation>
    </AttributeImplementationRelationship>
    <AttributeImplementationRelationship id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_CauseCodeSearchArgument-relCustomerCallHeader_SerialNumber">
      <position>3</position>
      <componentImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall">EMCustomerCallBOD</componentImplementation>
      <attributeImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_SerialNumber">CustomerCallHeader_SerialNumber</attributeImplementation>
    </AttributeImplementationRelationship>
    <AttributeImplementationRelationship id="biiEMCustomerCallBOD-compEMCustomerCall-attrCustomerCallHeader_CauseCodeSearchArgument-relERPReportedProblem">
      <position>4</position>
      <componentImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall">EMCustomerCallBOD</componentImplementation>
      <attributeImplementation idref="#biiEMCustomerCallBOD-compEMCustomerCall-attrERPReportedProblem">ERPReportedProblem</attributeImplementation>
    </AttributeImplementationRelationship>
  </AttributeImplementation>
  <MethodImplementation id="biiEMCustomerCallBOD-methOnProcess">
    <name>OnProcess</name>
    <event idref="EMCustomerCallBOD_BID.bi#bidEMCustomerCall0-eventProcess">Process</event>
    <processingOrder>batch</processingOrder>
    <beforeExecuteHookExpression>&#x9;io.cancel = false&#xD;&#xA;&#xD;&#xA;&#x9;RETIFNOK(tcbod.dll0040.actions.before.processing.incoming.request(&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;i.request,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;io.cancel))&#xD;&#xA;&#xD;&#xA;&#x9;return(0)</beforeExecuteHookExpression>
    <onExecuteHookExpression>&#x9;RETIFNOK(txcom.dll9003.Hook.OnExecute.EMCustomerCallBOD.OnProcess(&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;i.request,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;o.response,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;o.result))&#xD;&#xA;&#xD;&#xA;&#x9;return(0)&#xD;&#xA;&#xD;&#xA;&#x9;</onExecuteHookExpression>
    <afterExecuteHookExpression>&#x9;RETIFNOK(tcbod.dll0040.actions.after.processing.incoming.request(&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;i.request,&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;o.result))&#xD;&#xA;&#xD;&#xA;&#x9;return(0)</afterExecuteHookExpression>
