    <onGetHookExpression>&#x9;domain&#x9;tsclm.cprl check.cprl1&#xD;&#xA;&#x9;domain&#x9;tscfg.sigr sigr1&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;o.CustomerCallHeader_Status_ReasonCode = &quot;&quot;&#xD;&#xA;&#x9;if not isspace(i.CustomerCallHeader_ActionCodeValue) then&#xD;&#xA;&#x9;&#x9;|* Fetch Sigr&#xD;&#xA;&#x9;&#x9;txcom.dll9002.get.serialized.item.group(i.CustomerCallHeader_Item, i.CustomerCallHeader_SerialNumber, sigr1)&#xD;&#xA;&#x9;&#x9;check.cprl1 = &quot;9999999999&quot;&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;select&#x9;tsclm905.*&#xD;&#xA;&#x9;&#x9;from&#x9;tsclm905&#xD;&#xA;&#x9;&#x9;where&#x9;tsclm905.sigr = {:sigr1}&#xD;&#xA;&#x9;&#x9;and&#x9;(tsclm905.cprl = {:i.ERPReportedProblem}&#xD;&#xA;&#x9;&#x9;or&#x9;tsclm905.cprl = {:check.cprl1} &#xD;&#xA;&#x9;&#x9;or&#x9;tsclm905.cprl = &quot;&quot;)&#xD;&#xA;&#x9;&#x9;and&#x9;tsclm905.opcv.c = {:i.CustomerCallHeader_ActionCodeValue}&#xD;&#xA;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;o.CustomerCallHeader_Status_ReasonCode = tsclm905.sear.c&#xD;&#xA;&#x9;&#x9;&#x9;io.CustomerCallHeader_Status_ReasonCode.isSet = true&#xD;&#xA;&#x9;&#x9;endselect&#xD;&#xA;&#x9;endif&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;return(0)</onGetHookExpression>
