function long SetSelection_new1(xmlNode SelectionNode)
{
	long	ret
	xmlNode	AttributeNode
	string	SelectionAttribute(256)
	boolean	postfilter
	xmlnode filteredAttributes
	xmlnode	filter.attribute

	AttributeNode = xmlGetFirstChild(SelectionNode)
	while AttributeNode <> 0
		ret = xmlGetData(AttributeNode, SelectionAttribute)
		RETIFNOK(SetSelectionVariable_new1(strip$(SelectionAttribute)))
		AttributeNode = xmlGetRightSibling(AttributeNode)
	endwhile
	
	|* Set selected for postfilter attributes
	RETIFNOK(txclm.bl900st00.get.postfilter(postfilter))
	if postfilter then
		RETIFNOK(txclm.bl900st00.get.filteredAttributes(
					filteredAttributes))
		filter.attribute = xmlGetFirstChild(filteredAttributes)
		while filter.attribute <> 0
			on case xmlData$(filter.attribute)
			case "EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID":
				EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_accountingEntity":
				EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_accountingEntity.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_location":
				EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_location.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_lid":
				EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_lid.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_AlternateDocumentID_ID":
				EMCustomerCallBOD.CustomerCallHeader_AlternateDocumentID_ID.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_DisplayID":
				EMCustomerCallBOD.CustomerCallHeader_DisplayID.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_LastModificationDateTime":
				EMCustomerCallBOD.CustomerCallHeader_LastModificationDateTime.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_LastModificationPerson":
				EMCustomerCallBOD.CustomerCallHeader_LastModificationPerson.select = true
