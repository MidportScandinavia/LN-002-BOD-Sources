function long txclm.bl900sb00.Show_new(
					const xmlnode i.RequestArgument,
					ref xmlnode o.ResponseArgument,
					ref xmlnode o.ResultArgument)
{
	xmlNode	ResponseEMCustomerCallBODNode
	boolean	doFetch
	boolean	EMCustomerCallBOD_cancel
	long	bl.retval
	long	duml

	duml = 0
	bl.current.method = "Show"
	bl.processingScope = REQUEST
		
	RETIFNOK2(createResponseObject(o.ResponseArgument, "Show"))
	RETIFNOK2(createResultObject(o.ResultArgument))
	RETIFNOK2(selectResponseNode(o.ResponseArgument, ResponseEMCustomerCallBODNode))

	make.xmlArguments.global(i.RequestArgument,
				 o.ResponseArgument,
				 o.ResultArgument)
	txclm.bl900st00.initialize.tables()


	doFetch = true
	bl.result = Handle.Request.Show.EMCustomerCallBOD_new(i.RequestArgument, 
				o.ResponseArgument, o.ResultArgument,
				ResponseEMCustomerCallBODNode, EMCustomerCallBOD_cancel)

	bl.retval = bl.result
	if bl.result <> 0 then
		|* Add used query to response.
		add.executed.queries.to.response.Show.EMCustomerCallBOD(o.resultArgument, true)
		handle.messages(o.responseArgument,
		o.resultArgument,
		true)
        bl.ret = xmlDelete(o.ResponseArgument)
        o.ResponseArgument = 0
	else
	 	if log.query then
			|* Add used query to response.
			add.executed.queries.to.response.Show.EMCustomerCallBOD(o.ResponseArgument, false)
		endif
		handle.messages(o.ResponseArgument,
			o.ResultArgument, false) |* put mess in response
	endif
		RETIFNOK2_LIST_NEW(txclm.bl900st00.finalize.EMCustomerCallBOD.Show())
		
		RETIFNOK2_LIST_NEW(txclm.bl900st00.finalize.request.Show())

	return(bl.retval)
}

	     
function add.executed.queries.to.response.Show.EMCustomerCallBOD(xmlnode	io.response,
					boolean		i.error)
{
	xmlnode	log.node
	xmlnode mess.node
	xmlnode	curr.node
	long	i, ret
	xmlnode	bnode
	string hookname(128)
	string filterExpression(1024)
	boolean	postFilter
	xmlnode	filter

	if txclm.bl900st00.return.query.status.EMCustomerCallBOD() = QUERY.INACTIVE then
		return
	endif
	if i.error then
		| we cannot assume that the result is not empty or has no message details
		if xmlGetFirstChild(io.response) = 0 then
			mess.node = io.response
		else
			log.node = xmlFindFirstMatch("<>.<MessageDetails>", io.response)
			if log.node = 0 then
				log.node = xmlNewNode("MessageDetails", XML_ELEMENT, io.response)
			endif
		endif
	else
		log.node = xmlFindFirstMatch("<>.<InformationArea>", io.response)
		if log.node = 0 then
			log.node = xmlNewNode("InformationArea", XML_ELEMENT, io.response)
		endif
		mess.node = xmlNewNode("Message", XML_ELEMENT, log.node)
		ret = xmlSetAttribute(mess.node, "ID", "ID000001")
	endif

	curr.node = xmlNewDataElement("messageCode", "QueryLog", mess.node)
	curr.node = xmlNewDataElement("messageType", "Information", mess.node)
	curr.node = xmlNewDataElement("messageText", "Executed Queries for method Show.",
				mess.node)
	curr.node = xmlNewDataElement("messageSource","SQL Query",
				mess.node)
	mess.node = xmlNewNode("MessageReference", XML_ELEMENT, mess.node)
	curr.node = xmlNewDataElement("messageReferenceType", "logEntry", mess.node)
	curr.node = xmlNewNode("messageReferenceInfo", XML_ELEMENT, mess.node)
	for i = 1 to txclm.bl900st00.retrieve.table_alias.count()
		if i = 1 then
			mess.node = xmlNewNode("Table_Aliases",XML_ELEMENT, curr.node)
		endif
		bnode = xmlNewDataElement("t" & str$(i),
			strip$(txclm.bl900st00.retrieve.table_alias(i)), mess.node)
	endfor
	mess.node = xmlNewNode("ComponentFilterHook", XML_ELEMENT, curr.node)
	mess.node = xmlNewNode("Filter", XML_ELEMENT, curr.node)
	ret = txclm.bl900st00.get.filter.expression(filterExpression)
	bnode = xmlNewDataElement("Expression", filterExpression, mess.node)
	mess.node = xmlNewNode("PostFilter", XML_ELEMENT, curr.node)
	ret = txclm.bl900st00.get.postfilter(postfilter)
	if postfilter then
		|* for postfiltering the original filter is used
		ret = txclm.bl900st00.get.filter(filter)
		ret = xmlDuplicateAndAppendToChilds(mess.node, filter)
	endif
	ret = xmlSetAttribute(mess.node, "postfiltering", postfilter?"true":"false")

	log.node = xmlNewNode("EMCustomerCallBOD",XML_ELEMENT, curr.node)

	if txclm.bl900st00.query.on.hook.EMCustomerCallBOD.Show(hookname) then
	mess.node = xmlNewDataElement("HOOK", 
		"Query is executed in hook " & strip$(hookname), log.node)
	else
	|* Read and Add query.
	mess.node = xmlNewDataElement("select", 
		txclm.bl900st00.retrieve.select.clause.EMCustomerCallBOD(), log.node)
	mess.node = xmlNewDataElement("from", 
		txclm.bl900st00.retrieve.from.clause.EMCustomerCallBOD(), log.node)
	mess.node = xmlNewDataElement("where", 
		txclm.bl900st00.retrieve.where.clause.EMCustomerCallBOD(), log.node)
	mess.node = xmlNewDataElement("orderby", 
		txclm.bl900st00.retrieve.orderby.clause.EMCustomerCallBOD(), log.node)
	for i = 1 to txclm.bl900st00.retrieve.selectbind.count.EMCustomerCallBOD()
		if i = 1 then
			mess.node = xmlNewNode("selectbind",XML_ELEMENT, log.node)
		endif
		bnode = xmlNewDataElement("_" & str$(i),
			strip$(txclm.bl900st00.retrieve.selectbind.clause.EMCustomerCallBOD(i)), mess.node)
	endfor
	for i = 1 to txclm.bl900st00.retrieve.wherebind.count.EMCustomerCallBOD()
		if i = 1 then
			mess.node = xmlNewNode("wherebind",XML_ELEMENT, log.node)
		endif
		bnode = xmlNewDataElement("_"& str$(i),
			strip$(txclm.bl900st00.retrieve.wherebind.clause.EMCustomerCallBOD(i)), mess.node)
	endfor
	endif
	if txclm.bl900st00.return.query.status.EMCustomerCallBOD() = QUERY.ERROR then
		ret = xmlsetAttribute(log.node, "Error_status", "Error")
		return
	endif
	ret = xmlsetAttribute(log.node, "fetches", txclm.bl900st00.retrieve.fetch.count.EMCustomerCallBOD())
	
	|* Add sub components.
}

	     
function long Handle.Request.Show.EMCustomerCallBOD_new(
			const		xmlNode	i.RequestEMCustomerCallBODNode,
			ref			xmlNode	io_Show.ResponseArgument, 
			ref			xmlNode	io_Show.ResultArgument,
			const		xmlNode	i.ResponseEMCustomerCallBODNode,
			ref		boolean	o.cancel)
{
	long	ret
	boolean	fetching
	xmlNode	Response.EMCustomerCallBODNode
	boolean	selection.present
	xmlnode	ControlAreaNode
	long	fetch.count
	boolean sortingExpressionSet
	boolean	TagFound
	string  Value(1024)
	xmlnode	filter
	boolean	postfilter
	xmlnode	metaDataForFilter
	boolean	postfilter.valid

	ret = 0
	bl.result = 0
	Response.EMCustomerCallBODNode = 0

	ControlAreaNode = xmlFindFirst("ControlArea", i.RequestEMCustomerCallBODNode)
	if txclm.bl900st00.return.query.status.EMCustomerCallBOD() <> QUERY.FETCH then
		RETIFNOK5_LIST(txclm.bl900st00.initialize.request.Show())
	endif
	|* Get sortingExpression from the ControlAreaNode Node
	RETIFNOK6_LIST(getValue(ControlAreaNode, 
			"ControlArea.sortingExpression",
			"<ControlArea>.<sortingExpression>",
			false, Value, TagFound),
			txclm.bl900st00.finalize.set.EMCustomerCallBOD.Show())
	if Tagfound then
		if not isspace(Value) then
			dal.set.error.message("tlbctsb0050")
			|* No valid sortingExpression received
			|* (a non-empty sortingExpression is not supported).
			txclm.bl900st00.finalize.set.EMCustomerCallBOD.Show()
			return(DALHOOKERROR)					
		endif
		sortingExpressionSet = true
	else
		sortingExpressionSet = false
	endif
	
	|* Set sortingExpression to protected layer
	RETIFNOK6_LIST(txclm.bl900st00.set.sorting.expression(sortingExpressionSet),
			txclm.bl900st00.finalize.set.EMCustomerCallBOD.Show())

	|* Set filter to protected layer and determine postfiltering
	filter = xmlFindFirst("Filter", ControlAreaNode)
	RETIFNOK5_LIST(txclm.bl900st00.set.request.filter(filter))

	|* Get list of components with parent components
	RETIFNOK5_LIST(txclm.bl900st00.get.postfilter(postfilter))								
	if postfilter then	
		metaDataForFilter = Show.getMetaDataForFilter()
	endif

	CONTINUEIFNOK(Show,
			io_Show.ResponseArgument, io_Show.ResultArgument,
