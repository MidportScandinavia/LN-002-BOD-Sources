				"DocumentDateTime"), "DocumentDateTime", strip$(value)))
		endif
	endif
	|* Reading output for group/attribute CustomerCallHeader_Description
	string	CustomerCallHeader_Description.value(1024, 2)
	boolean	CustomerCallHeader_Description.valueIsSet(2)
	if EMCustomerCallBOD.CustomerCallHeader_Description.select then
		g.node = 0
		RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_Description.Mapper(
			CustomerCallHeader_Description.value, CustomerCallHeader_Description.valueIsSet))
