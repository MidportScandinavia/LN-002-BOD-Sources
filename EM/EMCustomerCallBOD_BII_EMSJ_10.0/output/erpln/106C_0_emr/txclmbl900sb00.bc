	#define CHECK_TOOLS_VERSION(response, result)
^	| The Business Studio version used to generate this business object
^	| requires Enterprise Server 8.4.2 or higher or Enterprise Server
^	| 8.3 or 8.4 with solution 236710.
^	| For that reason this define is used at the start of each method.
^	if not txclm.bl900st00.is.business.studio.supported() then
^		dal.set.error.message("@To use this business object, use Enterprise Server 8.4.2 or higher or install solution 236710")
^		response = 0
^		result = xmlNewNode("Result")
^		handle.messages(response, result, true) | add messages to result
^		return(DALHOOKERROR)
^	endif

	#define CHECK_TOOLS_VERSION_PUB_EVENT(response, result)
^	| If Enterprise Server 8.3 or lower is used, the SubscribeEvent method
^	| will fail. So the PublishEvent method can immediately return 0
^	| (= OK), to avoid fatal errors when invoking non-existing tl code.
^	if not txclm.bl900st00.is.business.studio.supported() then
^		result = 0
^		response = xmlNewNode("PublishEventResponse")
^		return(0) | OK
^	endif

