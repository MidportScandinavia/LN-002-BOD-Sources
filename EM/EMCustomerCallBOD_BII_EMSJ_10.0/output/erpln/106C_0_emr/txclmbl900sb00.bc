		dal.set.error.message("tlbctsb0003", "EMCustomerCallBOD.ERPWarrantyType")
		return(DALHOOKERROR)
	endif
	enum.long = rdi.ctoe("tstdm.wrtp", strip$(i.value))
	if enum.long < 1 then
		dal.set.error.message("tlbctsb0002", strip$(i.value),
			"tstdm.wrtp")
		return(DALHOOKERROR)
	endif
	l.ERPWarrantyType = ltoe(enum.long)
	RETIFNOK(tlbct.dll1000.domain.check.value(i.value,
		"tstdm.wrtp", "tstdm.wrtp", "ERPWarrantyType"))
	RETIFNOK(txclm.bl900st00.set.EMCustomerCallBOD.ERPWarrantyType(
			l.ERPWarrantyType))
