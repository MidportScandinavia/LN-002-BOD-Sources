function long txclm.bl900sb00.set.EMCustomerCallBOD.ERPCallCosted.Mapper(			
	const	string	i.value)				
{
	domain	tcyesno	l.ERPCallCosted

	long enum.long

	if isspace(i.value) then
		dal.set.error.message("tlbctsb0003", "EMCustomerCallBOD.ERPCallCosted")
		return(DALHOOKERROR)
	endif
	enum.long = rdi.ctoe("tcyesno", strip$(i.value))
	if enum.long < 1 then
		dal.set.error.message("tlbctsb0002", strip$(i.value),
			"tcyesno")
		return(DALHOOKERROR)
	endif
	l.ERPCallCosted = ltoe(enum.long)
	RETIFNOK(tlbct.dll1000.domain.check.value(i.value,
		"tcyesno", "tcyesno", "ERPCallCosted"))
	RETIFNOK(txclm.bl900st00.set.EMCustomerCallBOD.ERPCallCosted(
			l.ERPCallCosted))
	return(0)
}

