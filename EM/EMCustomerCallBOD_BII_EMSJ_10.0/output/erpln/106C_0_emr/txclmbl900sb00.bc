function extern string txclm.bl900sb00.GetSchemaVersion()
{
       DllUsage
              This method returns the BID Schema Version or an empty string
              if the schema version is unknown.
       EndDllUsage

       return("1.0")

}

function extern string txclm.bl900sb00.GetBusinessInterfaceType()
{
       DllUsage
              This method returns the type of the Business Interface as a
              lowercase string or an empty string if the type is unknown.
              For example, it can be used to check if the Business Object
              is a BOD.
       EndDllUsage
 
       return("bod")
}

