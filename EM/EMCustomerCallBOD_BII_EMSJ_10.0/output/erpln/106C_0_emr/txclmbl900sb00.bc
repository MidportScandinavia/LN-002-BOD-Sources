function boolean ml.enabled()
{
| Checks if the environment is multi-language enabled and the multi-language
| functions are present in tlbctdll1000. Only if both conditions are met, the
| multi-language functionality can be used.

static	boolean	initialized
static	boolean	enabled
	long	dll.id
	long	func.id

	if not initialized then
		enabled = false
		if ml_is_active() then
			dll.id = load_dll("otlbctdll1000")
			func.id = get_function(dll.id, "tlbct.dll1000.getMLValue")
			if func.id > 0 then
				enabled = true
			endif
		endif
		initialized = true
	endif
	
	return(enabled)
}

function long getMLValue(
	const	xmlNode	i.Node,
	const	string	i.name,
	const	string	i.tag,
		boolean	i.mandatory,
	ref	string	io.value,
	ref	boolean	o.tagfound)
{
| Pre: ml.enabled() is true
static	long	dll.id
static	long	func.id
static	boolean	initialized
	long	ret
	long	retval
	
	if not initialized then
		dll.id = load_dll("otlbctdll1000")
		func.id = get_function(dll.id, "tlbct.dll1000.getMLValue")
		initialized = true
	endif
	ret = exec_function(dll.id, func.id, retval, i.Node, i.name, i.Tag,
				i.mandatory, io.value, o.tagfound)
	return(retval)
}

