			case "EMCustomerCallBOD.CustomerCallHeader_DocumentDateTime":
				EMCustomerCallBOD.CustomerCallHeader_DocumentDateTime.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_Description":
				EMCustomerCallBOD.CustomerCallHeader_Description.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_Note":
				EMCustomerCallBOD.CustomerCallHeader_Note.select = true
				break
			case "EMCustomerCallBOD.CustomerCallHeader_DocumentReference":
				EMCustomerCallBOD.CustomerCallHeader_DocumentReference.select = true
