function boolean must.build.selection.node(xmlnode i.selection)
{
	if i.selection = 0 or xmlGetFirstChild(i.selection) = 0 then
		return(true)
	endif

	return(false)
}

  


function extern long txclm.bl900sb00.OnProcess(
					ref xmlNode i.RequestArgument,
					ref xmlNode o.ResponseArgument,
					ref xmlNode o.ResultArgument)
{
	DllUsage
		This method processes OnProcess events as requested in
		the XML Request message.
		If success, the XML Response is filled.
		Errors are put in the XML Result message.
	EndDllUsage

	CHECK_TOOLS_VERSION(o.ResponseArgument, o.ResultArgument)

	RETIFNOK2(txclm.bl900st00.execute.EMCustomerCallBOD.OnProcess(
						i.RequestArgument, o.ResponseArgument, o.ResultArgument))

	handle.messages(o.ResponseArgument,
			o.ResultArgument, false) |* put mess in response
	return(0)
}

function extern long txclm.bl900sb00.PublishEvent(
					ref xmlNode i.RequestArgument,
					ref xmlNode o.ResponseArgument,
					ref xmlNode o.ResultArgument)
{
	DllUsage
		This method processes PublishEvent events as requested in
		the XML Request message.
		If success, the XML Response is filled.
		Errors are put in the XML Result message.
	EndDllUsage

	CHECK_TOOLS_VERSION_PUB_EVENT(o.ResponseArgument, o.ResultArgument)

	return(txclm.bl900st00.execute.EMCustomerCallBOD.PublishEvent(
			i.RequestArgument, o.ResponseArgument, o.ResultArgument))
}

|------------ GetIdentifierName() -----------------------

function extern long txclm.bl900sb00.GetIdentifierName(
	ref	string	o.name)
{
DllUsage
	This function must only be used by the Tools Add-On package.
	Do not use it in hook code or other libraries.
	Output: The identifier name (for addition of the variation ID).
	Return value: 0 (OK) or an error value.
EndDllUsage

	o.name = "<CustomerCallHeader>.<DocumentID>.<ID>"
	return(0) | OK
}

|------------ GetPublicIdentifiers() for EMCustomerCallBOD ------------

function extern long txclm.bl900sb00.EMCustomerCallBOD.GetPublicIdentifiers(
		ref		long		o.externalData)
{
DllUsage
	This function must only be used by the Tools Add-On package.
	Do not use it in hook code or other libraries.
	Precondition: internal identifiers have been set in the protected layer.
	Return value: 0 (OK) or an error value.
	In case of error a dal error message has been set.
EndDllUsage

#define ERR_IF(condition, component)
^		if condition then
^			dal.set.error.message("tlbctstgen", "PublishEvent", component, "EMCustomerCallBOD")
^			|* Error occurred in Method '%1$s' on component '%2$s' of Object '%3$s'.
^			return(DALHOOKERROR)
^		endif
#define ERR_IF(condition)	ERR_IF(condition, "")

	long	componentNode	| component instance node
	long	retl			| return value to be checked


	retl = handle.output.EMCustomerCallBOD.identifiers(0, componentNode)
	ERR_IF(retl <> 0)
	o.externalData = componentNode
	
	return(0) | OK
}

function long handle.output.EMCustomerCallBOD.identifiers(
					xmlNode i.Node,
			ref   	xmlNode o.Node)
{
| i.Node is parentNode
| o.Node is current component Node (is child of i.Node)
	string  value(1024) mb
	boolean	value.isSet
	xmlNode	g.Node

	| Create component node for EMCustomerCallBOD
	NEW.NODE("EMCustomerCallBOD", i.Node, o.Node)

	g.node = 0
	value = ""
	value.isSet = false
	EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID.select = true
	g.Node = createGroupNodes(o.Node, "<CustomerCallHeader>.<DocumentID>.<ID>", "ID")
	if EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID.select then
		RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID.Mapper(value, value.isSet))
		if value.isSet then
			RETIFNOK4(xmlAppendToChilds(g.node, lval(strip$(value))))
		endif
	endif
	return(0)
}


	     
	     
#define	QUERY.INACTIVE		0
#define QUERY.INIT			1
#define QUERY.START			2
#define	QUERY.FETCH			3
#define QUERY.END			4
#define QUERY.ERROR			99
#define RETIFNOK2_LIST_NEW(...)
^               bl.result = ...
^               if bl.result <> 0 then
^                       handle.messages(o.responseArgument,
^					o.resultArgument,
^					true)
^                       bl.ret = xmlDelete(o.ResponseArgument)
^                       o.ResponseArgument = 0
^                       return(bl.result)
^               endif

#define	RETIFNOK5_LIST(...)
^		bl.result = ...
^		if bl.result <> 0 then
^			return(bl.result)
^		endif

#define	RETIFNOK6_LIST(STMT, STMT_ERR)
^		bl.result = STMT
^		if bl.result <> 0 then
^			STMT_ERR
^			return(bl.result)
^		endif


	     
