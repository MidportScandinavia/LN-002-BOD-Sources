	const	string	i.value)				
{
	domain	tcyesno	l.CustomerCallHeader_StatusError

	long enum.long

	if isspace(i.value) then
		dal.set.error.message("tlbctsb0003", "EMCustomerCallBOD.CustomerCallHeader_StatusError")
		return(DALHOOKERROR)
	endif
	enum.long = rdi.ctoe("tcyesno", strip$(i.value))
	if enum.long < 1 then
		dal.set.error.message("tlbctsb0002", strip$(i.value),
			"tcyesno")
		return(DALHOOKERROR)
	endif
	l.CustomerCallHeader_StatusError = ltoe(enum.long)
	RETIFNOK(tlbct.dll1000.domain.check.value(i.value,
		"tcyesno", "tcyesno", "CustomerCallHeader_StatusError"))
	RETIFNOK(txclm.bl900st00.set.EMCustomerCallBOD.CustomerCallHeader_StatusError(
			l.CustomerCallHeader_StatusError))
