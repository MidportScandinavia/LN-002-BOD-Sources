function long Show.handle.output.EMCustomerCallBOD_new(
				xmlnode	i.Node,
			ref	xmlnode	o.Node)
{
	string	value(1024) mb
	boolean	value.isSet
	long	ret
	long	g.node

	value = ""
	value.isSet = false
	ret = 0
	g.node = 0
	NEW.NODE("EMCustomerCallBOD", i.Node, o.Node)

	|* Reading output for group/attribute CustomerCallHeader_DocumentID
	|* Reading output for group/attribute CustomerCallHeader_DocumentID_ID
	if EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID.select then
		RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID.Mapper(value, value.isSet))
		if value.isSet and lval(strip$(value)) <> 0 then
			g.node = createGroupNodes(o.Node, "<CustomerCallHeader>.<DocumentID>.<ID>", "ID")
			ret = xmlDelete(xmlFindFirstMatch("<>.<CustomerCallHeader>.<DocumentID>.<ID>", o.Node))
			RETIFNOK4(xmlAppendToChilds(g.node, lval(strip$(value))))
		|* Qualifier
		if EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_accountingEntity.select then
			RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_accountingEntity.Mapper(value, value.isSet))
			if value.isSet then
				ret = xmlsetAttribute(xmlFindFirstMatch("<>.<CustomerCallHeader>.<DocumentID>.<ID>", o.Node), "accountingEntity", strip$(value))
			endif
		endif
		|* Qualifier
		if EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_location.select then
			RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_location.Mapper(value, value.isSet))
			if value.isSet then
				ret = xmlsetAttribute(xmlFindFirstMatch("<>.<CustomerCallHeader>.<DocumentID>.<ID>", o.Node), "location", strip$(value))
			endif
		endif
		|* Qualifier
		if EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_lid.select then
			RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID_lid.Mapper(value, value.isSet))
			if value.isSet then
				ret = xmlsetAttribute(xmlFindFirstMatch("<>.<CustomerCallHeader>.<DocumentID>.<ID>", o.Node), "lid", strip$(value))
			endif
		endif
		endif
	endif
	|* Reading output for group/attribute CustomerCallHeader_AlternateDocumentID
	|* Reading output for group/attribute CustomerCallHeader_AlternateDocumentID_ID
	if EMCustomerCallBOD.CustomerCallHeader_AlternateDocumentID_ID.select then
		RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_AlternateDocumentID_ID.Mapper(value, value.isSet))
		if value.isSet then
			RETIFNOK4(xmlRewriteDataElement(createGroupNodes(o.Node, "<CustomerCallHeader>.<AlternateDocumentID>.<ID>", 
				"ID"), "ID", strip$(value)))
		endif
	endif
	|* Reading output for group/attribute CustomerCallHeader_DisplayID
	if EMCustomerCallBOD.CustomerCallHeader_DisplayID.select then
		RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_DisplayID.Mapper(value, value.isSet))
		if value.isSet then
			RETIFNOK4(xmlRewriteDataElement(createGroupNodes(o.Node, "<CustomerCallHeader>.<DisplayID>", 
				"DisplayID"), "DisplayID", strip$(value)))
		endif
	endif
	|* Reading output for group/attribute CustomerCallHeader_LastModificationDateTime
	if EMCustomerCallBOD.CustomerCallHeader_LastModificationDateTime.select then
		RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_LastModificationDateTime.Mapper(value, value.isSet))
		if value.isSet then
			RETIFNOK4(xmlRewriteDataElement(createGroupNodes(o.Node, "<CustomerCallHeader>.<LastModificationDateTime>", 
				"LastModificationDateTime"), "LastModificationDateTime", strip$(value)))
		endif
	endif
	|* Reading output for group/attribute CustomerCallHeader_LastModificationPerson
	|* Special Implementation for EMCustomerCallBOD.CustomerCallHeader_LastModificationPerson
	if EMCustomerCallBOD.CustomerCallHeader_LastModificationPerson.select then
		RETIFNOK(txclm.bl900sb00.get.EMCustomerCallBOD.CustomerCallHeader_LastModificationPerson.Mapper(value, value.isSet))
