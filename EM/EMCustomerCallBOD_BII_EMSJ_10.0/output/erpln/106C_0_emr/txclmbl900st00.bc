function extern long txclm.bl900st00.finalize.request.Show(...)
{
	DllUsage
	EndDllUsage

	bl.method.result = ( get.argc() > 0 ) ? get.long.arg(1) : 0

	if bl.before.initialize <> 0 then
		bl.before.initialize = 0
	endif

	set.component.init.vars.to.false()

	return(bl.method.result)
}

function extern long txclm.bl900st00.finalize.EMCustomerCallBOD.Show()
{
	DllUsage
	EndDllUsage
	long	ret

    if not bl.performing.ShowAndPublishBOD then
	clean.up.sql.data.EMCustomerCallBOD()
	if bl.sql.pointer.EMCustomerCallBOD <> 0 then
		ret = sql.close(bl.sql.pointer.EMCustomerCallBOD)
		bl.sql.pointer.EMCustomerCallBOD = 0
	endif
	bl.EMCustomerCallBOD.query.status = QUERY.INACTIVE
    endif

	return(0)
}

function extern long txclm.bl900st00.initialize.request.Show()
{
	DllUsage
	EndDllUsage

	bl.method = "Show"
	bl.method.result = 0	

	set.component.init.vars.to.false()

    if not bl.performing.ShowAndPublishBOD then
	clean.up.sql.data.EMCustomerCallBOD()
    endif
	bl.EMCustomerCallBOD.query.status = QUERY.INACTIVE

	return(bl.method.result)
}

