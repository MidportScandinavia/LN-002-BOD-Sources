Input	other parameters identifiers for the components root table
	i.actionCode          action code
	i.documentId          document ID
	i.revisionId          revision ID
	i.variationId         variation ID
	i.tenantId            tenant ID
	i.accountingEntityId  accounting entity ID
	i.locationId          location ID
	i.settings		XML containing additional settings (optional);
				refer to the developer's documentation for more information
Output	o.bodInfo	XML containing logging info on published BODs and message size
	return value	0 (OK) or DALHOOKERROR (Error)
EndDllUsage

	long	identifiersXml	| xml containing identifying attributes and their values
	long	metadataXml	| xml containing metadata
	long	o.result	| result from tlbct.dll1000.CreateMetaDataNode
	long	bodInfoXml	| xml containing BOD publishing info
	long	retl		| return value to be checked
	long	duml		| dummy variable

	CHECK_TOOLS_VERSION_SHOW_AND_PUB(0)

	retl = txclm.bl900st00.EMCustomerCallBOD.SetInternalIdentifiers(
    			i.ERPCall,
			duml)
	DALHOOKERROR_IF(retl <> 0, "Show")

	DALHOOKERROR_IF(not txclm.bl900st00.EMCustomerCallBOD.GetInternalIdentifiersXml(
				i.ERPCall,
				identifiersXml),
			"Show")

	retl = tlbct.dll1000.CreateMetaDataNode(
				"otxclmbl900sb00", "txclm.bl900sb00.",
				"otxclmbl900st00", "txclm.bl900st00.",
				metadataXml,
				o.result,
				"bod")
	if o.result <> 0 then
		duml = xmlDelete(o.result) | not used
		o.result = 0	
	endif
	DALHOOKERROR_IF(retl <> 0, "Show")

	if get.argc() > 8 then
		i.settings = get.long.arg(9)
	else
		i.settings = 0
	endif
	bl.performing.ShowAndPublishBOD	= true
	retl = tlbct.dll1000.DefaultOnExecute.ShowAndPublishBOD(
			"EMCustomerCallBOD",
			"EMCustomerCall",
			"Show",	| event action
			identifiersXml,
			metadataXml,
			i.actionCode,
			i.documentId,
			i.revisionId,
			i.variationId,
			i.tenantId,
			i.accountingEntityId,
			i.locationId,
			i.settings,
			bodInfoXml)
	bl.performing.ShowAndPublishBOD	= false
			
	duml = xmlDelete(identifiersXml)
	identifiersXml = 0

	duml = xmlDelete(metadataXml)
	metadataXml = 0

	if get.argc() > 9 then
		put.long.arg(10, bodInfoXml)
	else
		duml = xmlDelete(bodInfoXml)
		bodInfoXml = 0
	endif

	DALHOOKERROR_IF(retl <> 0, "Show") | error from ShowAndPublishBOD

	return(0) | OK
}

#undef DALHOOKERROR_IF(condition, action)

|------------------- Check whether publishing is on ---------------------------

function extern boolean txclm.bl900st00.EMCustomerCallBOD.EventMustBePublished(
	const	string		i.verb)
{
DllUsage
Desc    This function checks whether a 'subscription' exists for the specified
        noun and verb (in the current company).
Input   i.verb          : the BOD verb
Output  return value    : true if the BOD must be published (a 'subscription'
                          exists); false otherwise.
EndDllUsage

	CHECK_TOOLS_VERSION_SHOW_AND_PUB(false)

	return(tlbct.dll1000.bod.must.be.published("EMCustomerCall", i.verb))
}


