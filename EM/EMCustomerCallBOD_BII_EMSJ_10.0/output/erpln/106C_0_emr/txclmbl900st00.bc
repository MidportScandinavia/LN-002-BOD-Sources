|*********************** OCM helper functions **********************************

function boolean is.ocm.active(const string i.table)
{
	if (get.tools.tiv() >= 1800) then
		return(dbcm.is.cm.active(i.table))
	else
		return(false)
	endif
}

function long get.type.name(const string i.table, ref string o.obj.type)
{
	if (get.tools.tiv() >= 1800) then
		on case dbcm.get.type.name(i.table, o.obj.type)
		case 0:
			| OK
			return(0)
		case 1:
			| multiple object types found
			dal.set.error.message("@Cannot determine Object Type for " &
				"table '%1s': the table occurs in multiple Object Types.",
				i.table)
			return(DALHOOKERROR)
		default:
			| error
			dal.set.error.message("@Cannot determine Object Type for " &
				"table '%1$s' (error %2$d).", i.table, e)
			return(DALHOOKERROR)
		endcase
	else
		o.obj.type = ""
		return(0)
	endif
}

function long check.result.set.query.mode(long first, long second,
		const string i.obj.type, const string i.table)
{
	RETIFNOK(first)
	if second <> 0 then
		dal.set.error.message("@Cannot select Object Type '%s' for " &
				"table '%s' (error %d).", strip$(i.obj.type), i.table, e)
		return(DALHOOKERROR)
	endif
	return(0)
}
