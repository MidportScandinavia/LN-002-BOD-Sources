|------------ SetInternalIdentifiers() for all components ------------

function extern long txclm.bl900st00.SetInternalIdentifiers(
		long	i.internalData)
{
DllUsage
	This function must only be used by the Tools Add-On package
	or the public layer.
	Do not use it in hook code or other libraries.
	Return value: 0 (OK) or an error value.
	In case of error a dal error message has been set.
EndDllUsage

	string	component.name(50)
	domain  tcorno  local.EMCustomerCallBOD.ERPCall
	long	attributeNode	| child of instanceNode
	long	retl			| return value to be checked
	long	duml			| dummy variable

	attributeNode = 0
	retl = 0
	duml = 0
	component.name = xmlName$(i.internalData)

	on case component.name
	case "EMCustomerCallBOD":
		attributeNode = xmlFindFirstMatch("<EMCustomerCallBOD>.<ERPCall>",
							i.internalData)
		ERR_IF(attributeNode = 0, "EMCustomerCallBOD")

		local.EMCustomerCallBOD.ERPCall =
				xmlData$(attributeNode)
		retl = txclm.bl900st00.EMCustomerCallBOD.SetInternalIdentifiers(
				local.EMCustomerCallBOD.ERPCall,
					duml)
		ERR_IF(retl <> 0, "EMCustomerCallBOD") | incorrect component
		break
	default:
		ERR_IF(true, component.name) | incorrect component
	endcase

	return(0) | OK
}

