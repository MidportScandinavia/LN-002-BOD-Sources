		as set with 1 rows
		selectdo
			ret = txcom.dll9002.text.handling(i.ERPCall, tsclm100.cdf_cade, 3, o.CustomerCallHeader_CauseDescription) 
			if ret < 0 then
				dal.set.error.message("@ Error in Text Field" & str$(tsclm100.cdf_cade))
				return(DALHOOKERROR)
			endif
		endselect
	endif
	
	return(0)
}
