#context_off
#context_on "HOOK:onGetHook; ATTRIBUTE:EMCustomerCallBOD.CustomerCallHeader_ProblemComment"
function long Hook.OnGet.EMCustomerCallBOD.CustomerCallHeader_ProblemComment(
		domain	tcorno	i.ERPCall,
		boolean			i.ERPCall.isSet,
		domain	tsclm.long	i.CustomerCallHeader_BODRouter,
		boolean			i.CustomerCallHeader_BODRouter.isSet,
	ref domain	tcmcs.s999m	o.CustomerCallHeader_ProblemComment,
	ref boolean	io.CustomerCallHeader_ProblemComment.isSet)
{
io.CustomerCallHeader_ProblemComment.isSet = true

	if not isspace(i.ERPCall) then
		if i.CustomerCallHeader_BODRouter <> 5 then
			ret = tsclm.dll9003.append.all.transaction.text(i.ERPCall,TRUE, o.CustomerCallHeader_ProblemComment)
			if ret < 0 then
				dal.set.error.message("@ Error in Problem Comment Text Field")
				return(DALHOOKERROR)
			endif
		else
			if i.CustomerCallHeader_BODRouter = 5 then
				ret = tsbod.dll9001c.get.all.text.from.history(i.ERPCall, o.CustomerCallHeader_ProblemComment) 
			endif
		endif	
	endif
	
	return(0)
}
