function extern string txclm.bl900st00.retrieve.table_alias(long	i)
{
	DllUsage
	EndDllUsage

	on case i
	case 1:
		return ("t1 tsclm100 (1) [Component:EMCustomerCallBOD]")
	case 2:
		return ("t2 tsclm105 (2) [Component:EMCustomerCallBOD]")
	endcase

	return("")
}

function extern long txclm.bl900st00.retrieve.table_alias.count()
{
	DllUsage
	EndDllUsage

	return(2)
}

