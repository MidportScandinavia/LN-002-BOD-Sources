function string nonRootJoin.EMCustomerCallBOD.tsclm100_1()
{
	string	nonRootJoin(MAX_QUERY_LENGTH)
	
	nonRootJoin = ""
	|* add non-root table left join
	if tbl.ttsclm105 <> 0 and
	   (EMCustomerCallBOD.tsclm105_2.in.selection() or
	   bl.EMCustomerCallBOD.tsclm105_2.filter.is.set) then
		nonRootJoin = nonRootJoin & " left join tsclm105 " & EMCustomerCallBOD.tsclm105_2
		nonRootJoin = nonRootJoin & " on "
		nonRootJoin = nonRootJoin & EMCustomerCallBOD.tsclm105_2 & ".ccll = "
		nonRootJoin = nonRootJoin & EMCustomerCallBOD.tsclm100_1 & ".ccll"
		nonRootJoin = nonRootJoin & nonRootJoin.EMCustomerCallBOD.tsclm105_2()
	endif

	return(nonRootJoin)
}	

