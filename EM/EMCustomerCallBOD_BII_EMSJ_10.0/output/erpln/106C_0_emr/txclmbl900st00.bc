function clear.recent.DAL.error.messages()
{
	long	ret.bl
	string  MessageCode(25)
	string  MessageContent(256) mb
	long    MessageTypeCode

	while dal.count.messages(MSG.ALL) > bl.dal.nr.messages
		ret.bl = dal.get.last.message(MSG.ALL, MessageCode,
			MessageContent,
		   MessageTypeCode)
	endwhile
}

function set.current.number.of.DAL.messages()
{
	bl.dal.nr.messages = dal.count.messages(MSG.ALL)
}

function log.identifiers.DAL.message.EMCustomerCallBOD()
{
	| Because the application DAL does not always log all identifiers,
	| it would be difficult to determine which instance causes the
	| reported problem. Therefore, the identifiers are logged in this
	| function.
	dal.set.error.message("@Identifiers: CustomerCallHeader_DocumentID_ID=" &
			str$(bl.EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID)
		& ", ERPCall=" &
			trim$(bl.EMCustomerCallBOD.ERPCall)
	)
}

function long handle.result(long i.result)
{

	string	e.message(256) mb
	string	mscode(12)

	if i.result = 0 then
		return (0)
	endif
	if i.result = 0 or
	   i.result = DALHOOKERROR or
	   i.result = DALDBERROR or
	   i.result = DALNOSETPERM or
	   i.result = DALNOOBJPERM then
		|* error message already present
		if i.result <> 0 then
			dal.set.info.message("tlbctstgen",
				strip$(bl.method), strip$(bl.component),
				strip$(bl.bodesc))
			|* Error occurred in Method '%1$s' on component '2$s'
			|* of Object '%3$s'
		endif
		return(i.result)
	endif

	e.message = ""
	if i.result > 0 then
		|* get errormessage by messcode tlbcterrX
		mscode = "tlbcterr" & str$(i.result)
		e.message = sprintf$(form.text$(mscode),
					strip$(bl.method), strip$(bl.object))
	endif

	if i.result > 0 and pos(e.message, "???") = 0 then
		dal.set.error.message(mscode,
				bl.method, strip$(bl.object))
	else
		e.message = db.error.message()
		if isspace(e.message) then
			dal.set.error.message("tlbcts0021",
						strip$(bl.method),
						strip$(bl.object),
						i.result)
			|* Method '%1$s', Object '%2$s':
			|* error-code: %3$d ( Error description not present )
			tlbct.dll1000.log(__FILE__, __LINE__,
				sprintf$(form.text$("tlbcts0004"),
	 						i.result))
			|* Error description not present (code: %1$d).
		else
			dal.set.error.message("@" & e.message)
			dal.set.info.message("tlbctstgen",
				strip$(bl.method), strip$(bl.component),
				strip$(bl.bodesc))
			|* Error occurred in Method '%1$s' on component '2$s'
			|* of Object '%3$s'
		endif
	endif
	return(i.result)
}

function boolean is.field.ml.registered(
	const	string	i.table,
	const	string	i.field)
{
	string	col.name(17)
	long	ret
	long	colnr
	long	duml
	string	dums(1)
	
	colnr = 1
	repeat
		ret = rdi.table.column(i.table, colnr, col.name, dums, duml,
					duml, duml, duml, duml, dums, DB.MLF)
		if ret = 0 and strip$(col.name(10)) = i.field then
			return(true)
		endif
		inc(colnr)
	until ret <> 0
	
	return(false)
}

function long mle.cmp(
	const	string	i.string1,
	const	string	i.string2)
{
static	long	dll.id
static	long	func.id
static	boolean	initialized
	long	ret
	long	retval
	
	if not initialized then
		dll.id = load_dll("otlbctdll1000")
		func.id = get_function(dll.id, "tlbct.dll1000.mle.cmp")
		initialized = true
	endif
	if func.id = 0 then
		| fallback to single language
		return(strip$(i.string1) = strip$(i.string2) ? 0 : 1)
	else
		ret = exec_function(dll.id, func.id, retval, i.string1, i.string2)
	endif
	return(retval)
}

