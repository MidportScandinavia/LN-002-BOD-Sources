function extern
long txclm.bl900st00.execute.EMCustomerCallBOD.Show()
{
	DllUsage
	EndDllUsage
	long	ret

	if bl.sql.pointer.EMCustomerCallBOD <> 0 then
		ret = sql.fetch(bl.sql.pointer.EMCustomerCallBOD)
	else
		ret = ENOREC
	endif
	on case ret
	case 0:
		bl.fetches.EMCustomerCallBOD = bl.fetches.EMCustomerCallBOD + 1
		bl.EMCustomerCallBOD.query.status = QUERY.FETCH
		bl.tsclm100.set = true
		set.setters.after.fetch.EMCustomerCallBOD(true)
		return (0)
	case eendfile:
	case ENOREC:
		bl.EMCustomerCallBOD.query.status = QUERY.END
		set.setters.after.fetch.EMCustomerCallBOD(false)
		return (0)
	default:
		bl.EMCustomerCallBOD.query.status = QUERY.ERROR
		if ret = -1 then
			ret = handle.result(e)
		endif
		if MESSAGE_EXISTS("tlbcts0085") then
			dal.set.error.message("tlbcts0085", ret, "Show")
			|* Error %1$d in method %2$s
		else
			dal.set.error.message("@Error %d in method Show", ret)
		endif
		return (DALHOOKERROR)
	endcase
}

