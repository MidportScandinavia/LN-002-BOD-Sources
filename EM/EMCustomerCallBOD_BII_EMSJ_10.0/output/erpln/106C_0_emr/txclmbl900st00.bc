	bl.where.bind.counter.EMCustomerCallBOD = bl.where.bind.counter.EMCustomerCallBOD + 1
	if bl.where.bind.counter.EMCustomerCallBOD > bl.where.bind.max.EMCustomerCallBOD then
		bl.where.bind.max.EMCustomerCallBOD = bl.where.bind.max.EMCustomerCallBOD + 10
		alloc.mem(bl.where.bind.EMCustomerCallBOD, 82, bl.where.bind.max.EMCustomerCallBOD)
	endif
	bl.where.bind.EMCustomerCallBOD(1,bl.where.bind.counter.EMCustomerCallBOD) = i.attr.field
	o.number = bl.where.bind.counter.EMCustomerCallBOD
}

