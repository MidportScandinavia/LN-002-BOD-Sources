function string build.where.for.EMCustomerCallBOD.tsclm100_1(ref string sepa())
{
	string	field.where(MAX_QUERY_LENGTH)
	long	where.number

	if not EMCustomerCallBOD.tsclm100_1.in.selection() and
	   isspace(bl.FilterExpression) then
