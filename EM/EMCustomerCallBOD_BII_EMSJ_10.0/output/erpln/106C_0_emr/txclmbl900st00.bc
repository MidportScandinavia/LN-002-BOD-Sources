#context_on "HOOK:onGetHook; ATTRIBUTE:EMCustomerCallBOD.CustomerCallHeader_Description"
function long Hook.OnGet.EMCustomerCallBOD.CustomerCallHeader_Description(
		domain	tsclm.desc	i.ERPCallDescription,
		boolean			i.ERPCallDescription.isSet,
		domain	tsclm.desc	i.ERPSolutionDescription,
		boolean			i.ERPSolutionDescription.isSet,
	ref domain	tcmcs.long	o.CustomerCallHeader_Description(),
	ref boolean	io.CustomerCallHeader_Description.isSet())
{
long	duml

duml = set.mem(io.CustomerCallHeader_Description.isSet, true)

long		cnt
	long		node
	boolean	node.is.set

	set.mem(io.CustomerCallHeader_Description.isSet, false)

	cnt = 0

	if not isspace(i.ERPCallDescription) then
		inc(cnt)
	
		RETIFNOK(tcbod.dll0033.get.description.node(
				i.ERPCallDescription,
				DESCRIPTION_TYPE_PROBLEM,
				"",	|* languageID
				node,
				node.is.set))

		o.CustomerCallHeader_Description(cnt) = node
		io.CustomerCallHeader_Description.isSet(cnt) = node.is.set
	endif

	if not isspace(i.ERPSolutionDescription) then
		inc(cnt)
	
		RETIFNOK(tcbod.dll0033.get.description.node(
				i.ERPSolutionDescription,
				DESCRIPTION_TYPE_SOLUTION,
				"",	|* languageID
				node,
				node.is.set))

		o.CustomerCallHeader_Description(cnt) = node
		io.CustomerCallHeader_Description.isSet(cnt) = node.is.set
	endif

	return(0)
}
