function extern void txclm.bl900st00.set.xmlArguments(
					const xmlNode i.RequestArgument,
					const xmlNode i.ResponseArgument,
					const xmlNode i.ResultArgument)
{
	bl.RequestArgument  = i.RequestArgument
	bl.ResponseArgument = i.ResponseArgument
	bl.ResultArgument   = i.ResultArgument
}

function extern void txclm.bl900st00.initialize.tables()
{
static	boolean	initialized
	long	duml
	
	if initialized then
		return
	endif

	if rdi.table("tsclm100", duml, duml, len.ttsclm100, len.ttsclm100.real) = 0 then
		alloc.mem(rcd.ttsclm100,len.ttsclm100)
		tbl.ttsclm100 = db.bind("ttsclm100", rcd.ttsclm100)
	endif
	if rdi.table("tsclm105", duml, duml, len.ttsclm105, len.ttsclm105.real) = 0 then
		alloc.mem(rcd.ttsclm105,len.ttsclm105)
		tbl.ttsclm105 = db.bind("ttsclm105", rcd.ttsclm105)
	endif
	
	initialized = true
}

