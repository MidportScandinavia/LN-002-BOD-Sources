function set.component.init.vars.to.false()
{
	long	ret

	bl.EMCustomerCallBOD.initialize = false
	bl.SortingExpressionSet = false
	if bl.Filter <> 0 then
		ret = xmlDelete(bl.Filter)
	endif
	bl.Filter = 0
	if bl.FilteredAttributes <> 0 then
		ret = xmlDelete(bl.FilteredAttributes)
	endif
	bl.FilteredAttributes = 0
	bl.FilterExpression = ""
	bl.PostFilter = false
	set.permission.for.readonly.attributes(false)
}

