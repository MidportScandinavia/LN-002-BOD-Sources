	bl.EMCustomerCallBOD.ERPCall = i.ERPCall
	bl.EMCustomerCallBOD.ERPCall.set = true


	return(0) | OK
}

function extern long txclm.bl900st00.EMCustomerCallBOD.tsclm105.SetInternalIdentifiers(
		long	i.internal.data)
{
DllUsage
	This function must only be used by the Tools Add-On package
	or the public layer.
	Do not use it in hook code or other libraries.
	Return value: 0 (OK) or an error value.
	Error values:
	  -1: multiple root table rows match the settings of the non-root row
	  -2: no root table row matches the settings of the non-root row
	DALHOOKERROR: a dal error message has been set.
EndDllUsage

	long	attributeNode	| child of instanceNode
	boolean	row.fetched	| indicates if a row has been fetched already
	domain	tcorno	local.EMCustomerCallBOD.CustomerCallHeader_DisplayID
	domain	tcorno	local.EMCustomerCallBOD.ERPCall
	domain	tcorno	l.tsclm100.ccll
	long	sql

	| get values
	attributeNode = xmlFindFirst("ccll", i.internal.data)
	ERR_IF(attributeNode = 0, "EMCustomerCallBOD")
	local.EMCustomerCallBOD.CustomerCallHeader_DisplayID = 
			xmlData$(attributeNode)
	attributeNode = xmlFindFirst("ccll", i.internal.data)
	ERR_IF(attributeNode = 0, "EMCustomerCallBOD")
	local.EMCustomerCallBOD.ERPCall = 
			xmlData$(attributeNode)

	| perform joining query to get top-level identifiers
	row.fetched = false
	if tbl.ttsclm100 = 0 then
		return(-2) | no table, so no matching rows
	endif
	if sql = 0 then
		SET.ERROR.BYPASS.ON()
		sql = sql.parse(
			"select	tsclm100.ccll:1 " &
			"from	tsclm100 " &
			"	left outer join tsclm105 on tsclm100.ccll=tsclm105.ccll " &
			"where	tsclm105.ccll = :2 " &
			"	and tsclm105.ccll = :3 " &
			"", PARSE.DIALECT.6 + PARSE.SUPPRESS)
		SET.ERROR.BYPASS.OFF()
		if sql = 0 then
			| Parse query failed: assume that table does not exist.
			return(-2) | no matching rows
		endif
	endif
	sql.select.bind(sql, 1, l.tsclm100.ccll)
	sql.where.bind(sql, 2, local.EMCustomerCallBOD.CustomerCallHeader_DisplayID)
	sql.where.bind(sql, 3, local.EMCustomerCallBOD.ERPCall)
	if sql.exec(sql) <> 0 then
		| Execute query failed
		return(-2) | no matching rows
	endif
	while true
		on case sql.fetch(sql)
		case EENDFILE:
			if not row.fetched then
				sql.break(sql)
				return(-2) | no matching rows
			endif
			break
		case 0:
			if not row.fetched then
				row.fetched = true
				| set identifiers for current component
				bl.EMCustomerCallBOD.ERPCall = l.tsclm100.ccll
				bl.EMCustomerCallBOD.ERPCall.set = true

				| Set identifiers for parent components
			else
				sql.break(sql)
				return(-1) | multiple matching rows
			endif
			continue
		default:
			break
		endcase
		| stop fetching
		break
	endwhile
	sql.break(sql)

	return(0) | OK
}

function extern long txclm.bl900st00.EMCustomerCallBOD.GetRootTableIdentifiers(
	ref	long	o.internalData)
{
DllUsage
	This function must only be used by the Publisher DLL (included in the
	Tools Add-On package).
	Do not use it in hook code or other libraries.
	Return value: 0 (OK) or an error value.
	In case of error a dal error message has been set.
EndDllUsage

	long	attributeNode	| node containing attribute
	long	retl		| return value to be checked
	long	i

	o.internalData = xmlNewNode("Data")
	i = 0

	| add ccll / bl.EMCustomerCallBOD.CustomerCallHeader_DisplayID
	ERR_IF(not bl.EMCustomerCallBOD.CustomerCallHeader_DisplayID.set)
	attributeNode = xmlNewDataElement("columnValue",
					bl.EMCustomerCallBOD.CustomerCallHeader_DisplayID,
					o.internalData)
	ERR_IF(attributeNode = 0)
	retl = xmlSetAttribute(attributeNode, "column", "ccll")
	ERR_IF(retl = 0)

	| add ccll / bl.EMCustomerCallBOD.ERPCall
	ERR_IF(not bl.EMCustomerCallBOD.ERPCall.set)
	attributeNode = xmlNewDataElement("columnValue",
					bl.EMCustomerCallBOD.ERPCall,
					o.internalData)
	ERR_IF(attributeNode = 0)
	retl = xmlSetAttribute(attributeNode, "column", "ccll")
	ERR_IF(retl = 0)

	return(0) | OK
}

|------------ GetInternalIdentifiersXml() for EMCustomerCallBOD ------------

function boolean txclm.bl900st00.EMCustomerCallBOD.GetInternalIdentifiersXml(
     	domain  tcorno  i.ERPCall, 
	ref	long	o.identifiersXml)
{
| Create XML containing input for txclm.bl900st00.EMCustomerCallBOD.SetInternalIdentifiers()
| Return value: true = OK, false = error

	long	attributeNode	| xml node for attribute element
	long	duml			| dummy variable

	o.identifiersXml = xmlNewNode("EMCustomerCallBOD")
	if o.identifiersXml = 0 then
		return(false)
	endif
	attributeNode = xmlNewDataElement("ERPCall", i.ERPCall, o.identifiersXml)
	if attributeNode = 0 then
		duml = xmlDelete(o.identifiersXml)
		o.identifiersXml = 0
		return(false)
	endif
	return(true)
}
#define DALHOOKERROR_IF(condition, action)
^	if condition then
^		dal.set.error.message("tlbctst0014",
^			action, "EMCustomerCallBOD", "EMCustomerCallBOD")
^		| Unable to execute ShowAndPublish%1$sBOD for %2$s.%3$s.
^		return(DALHOOKERROR) 
^	endif

|------------ ShowAndPublishSyncBOD() for EMCustomerCallBOD ------------

function extern long txclm.bl900st00.EMCustomerCallBOD.ShowAndPublishSyncBOD(
     	domain  tcorno		i.ERPCall, 
	const	string		i.actionCode,
	const	string		i.documentId,
	const	string		i.revisionId,
	const	string		i.variationId,
	const	string		i.tenantId,
	const	string		i.accountingEntityId,
	const	string		i.locationId,
	[	long		i.settings ,
	ref	long		o.bodInfo ] )
{
DllUsage
Desc	This function publishes an event for the instance defined by the input parameters.
	- the values for the public identifying attributes are determined
	- the Show request is built and the Show is invoked (unless i.actionCode =
	  "Delete" and the component is the top-level component)
	- the metadata is retrieved
	- an event message is created (using the Show response if applicable)
	- the event message is published through PublishBOD().
	- in case of errors, DALHOOKERROR is returned
Input	other parameters identifiers for the components root table
	i.actionCode          action code
	i.documentId          document ID
	i.revisionId          revision ID
	i.variationId         variation ID
	i.tenantId            tenant ID
	i.accountingEntityId  accounting entity ID
	i.locationId          location ID
	i.settings		XML containing additional settings (optional);
				refer to the developer's documentation for more information
Output	o.bodInfo	XML containing logging info on published BODs and message size
	return value	0 (OK) or DALHOOKERROR (Error)
EndDllUsage

	long	identifiersXml	| xml containing identifying attributes and their values
	long	metadataXml	| xml containing metadata
	long	o.result	| result from tlbct.dll1000.CreateMetaDataNode
	long	bodInfoXml	| xml containing BOD publishing info
	long	retl		| return value to be checked
	long	duml		| dummy variable

	CHECK_TOOLS_VERSION_SHOW_AND_PUB(0)

	retl = txclm.bl900st00.EMCustomerCallBOD.SetInternalIdentifiers(
    			i.ERPCall,
			duml)
	DALHOOKERROR_IF(retl <> 0, "Sync")

	DALHOOKERROR_IF(not txclm.bl900st00.EMCustomerCallBOD.GetInternalIdentifiersXml(
				i.ERPCall,
				identifiersXml),
			"Sync")

	retl = tlbct.dll1000.CreateMetaDataNode(
				"otxclmbl900sb00", "txclm.bl900sb00.",
				"otxclmbl900st00", "txclm.bl900st00.",
				metadataXml,
				o.result,
				"bod")
	if o.result <> 0 then
		duml = xmlDelete(o.result) | not used
		o.result = 0	
	endif
	DALHOOKERROR_IF(retl <> 0, "Sync")

	if get.argc() > 8 then
		i.settings = get.long.arg(9)
	else
		i.settings = 0
	endif
	bl.performing.ShowAndPublishBOD	= true
	retl = tlbct.dll1000.DefaultOnExecute.ShowAndPublishBOD(
			"EMCustomerCallBOD",
			"EMCustomerCall",
			"Sync",	| event action
			identifiersXml,
			metadataXml,
			i.actionCode,
			i.documentId,
			i.revisionId,
			i.variationId,
			i.tenantId,
			i.accountingEntityId,
			i.locationId,
			i.settings,
			bodInfoXml)
	bl.performing.ShowAndPublishBOD	= false
			
	duml = xmlDelete(identifiersXml)
	identifiersXml = 0

	duml = xmlDelete(metadataXml)
	metadataXml = 0

	if get.argc() > 9 then
		put.long.arg(10, bodInfoXml)
	else
		duml = xmlDelete(bodInfoXml)
		bodInfoXml = 0
	endif

	DALHOOKERROR_IF(retl <> 0, "Sync") | error from ShowAndPublishBOD

	return(0) | OK
}

