#context_on "HOOK:conversionGetHook; ATTRIBUTE:EMCustomerCallBOD.CustomerCallHeader_CallTypeCode"
function extern long txclm.bl900st00.Hook.ConversionGet.EMCustomerCallBOD.CustomerCallHeader_CallTypeCode(
		domain tsclm.cllo	i.CustomerCallHeader_CallTypeCode,
	ref string	o.CustomerCallHeader_CallTypeCode,
	ref boolean	io.CustomerCallHeader_CallTypeCode.isSet)
{
on case i.CustomerCallHeader_CallTypeCode
	case tsclm.cllo.telep:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_PHONE
		break
	case tsclm.cllo.fax:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_FAX
		break
	case tsclm.cllo.modem:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_MODEM
		break
	case tsclm.cllo.letter:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_MAIL
		break
	case tsclm.cllo.internal:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_INTERNAL
		break
	case tsclm.cllo.email:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_EMAIL
		break
	case tsclm.cllo.other:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_OTHER
		break
	case tsclm.cllo.internet:
		o.CustomerCallHeader_CallTypeCode = CALL_TYPE_INTERNET
		break
	endcase

	return(0)
}
