function extern 
long txclm.bl900st00.get.EMCustomerCallBOD.CustomerCallHeader_CauseCodeSearchArgument(
					ref domain tcmcs.str100m o.value)
{
	DllUsage
	EndDllUsage

	long	duml

	duml = 0

	duml = txclm.bl900st00.get.EMCustomerCallBOD.CustomerCallHeader_CauseCode(
		bl.EMCustomerCallBOD.CustomerCallHeader_CauseCode)
		bl.EMCustomerCallBOD.CustomerCallHeader_CauseCode.set = 
			txclm.bl900st00.is.set.EMCustomerCallBOD.CustomerCallHeader_CauseCode()
	duml = txclm.bl900st00.get.EMCustomerCallBOD.CustomerCallHeader_Item(
		bl.EMCustomerCallBOD.CustomerCallHeader_Item)
		bl.EMCustomerCallBOD.CustomerCallHeader_Item.set = 
			txclm.bl900st00.is.set.EMCustomerCallBOD.CustomerCallHeader_Item()
	duml = txclm.bl900st00.get.EMCustomerCallBOD.CustomerCallHeader_SerialNumber(
		bl.EMCustomerCallBOD.CustomerCallHeader_SerialNumber)
		bl.EMCustomerCallBOD.CustomerCallHeader_SerialNumber.set = 
			txclm.bl900st00.is.set.EMCustomerCallBOD.CustomerCallHeader_SerialNumber()
	duml = txclm.bl900st00.get.EMCustomerCallBOD.ERPReportedProblem(
		bl.EMCustomerCallBOD.ERPReportedProblem)
		bl.EMCustomerCallBOD.ERPReportedProblem.set = 
			txclm.bl900st00.is.set.EMCustomerCallBOD.ERPReportedProblem()
	o.value = bl.EMCustomerCallBOD.CustomerCallHeader_CauseCodeSearchArgument

	RETIFNOK(Hook.OnGet.EMCustomerCallBOD.CustomerCallHeader_CauseCodeSearchArgument(
		bl.EMCustomerCallBOD.CustomerCallHeader_CauseCode,
		bl.EMCustomerCallBOD.CustomerCallHeader_CauseCode.set,
		bl.EMCustomerCallBOD.CustomerCallHeader_Item,
		bl.EMCustomerCallBOD.CustomerCallHeader_Item.set,
		bl.EMCustomerCallBOD.CustomerCallHeader_SerialNumber,
		bl.EMCustomerCallBOD.CustomerCallHeader_SerialNumber.set,
		bl.EMCustomerCallBOD.ERPReportedProblem,
		bl.EMCustomerCallBOD.ERPReportedProblem.set,
		o.value,
		bl.EMCustomerCallBOD.CustomerCallHeader_CauseCodeSearchArgument.set))

	bl.EMCustomerCallBOD.CustomerCallHeader_CauseCodeSearchArgument.get = true

	return(0)
}

