		where	tsclm100._index1 = {:i.ERPCall}
		and	(tsclm100.txte <> 0)
		as set with 1 rows
		selectdo
			ret = txcom.dll9002.text.handling(i.ERPCall, tsclm100.txte, 1, o.CustomerCallHeader_SolutionText) 
			if ret < 0 then
				dal.set.error.message("@ Error in Text Field" & str$(tsclm100.txte))
				return(DALHOOKERROR)
			endif
		endselect
	endif
	
	return(0)
}
