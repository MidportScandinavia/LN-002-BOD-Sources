function extern 
long txclm.bl900st00.execute.EMCustomerCallBOD.Read()
{
	DllUsage
	EndDllUsage

	long	result
	long	hold.context
	long	retl
	long	i
	
	retl = 0
	i = 0

	result = 0
	bl.component.result = 0
	hold.context = dal.get.context()
	dal.set.context(CTX_INTEGRATION)
	
	if not bl.EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID.set then
		dal.set.error.message("tlbctst0001",
			"EMCustomerCallBOD.CustomerCallHeader_DocumentID_ID")
		|* Mandatory protected attribute %1$s is not set.
		dal.set.context(hold.context)
		return(DALHOOKERROR)
	endif
	if not bl.EMCustomerCallBOD.ERPCall.set then
		dal.set.error.message("tlbctst0001",
			"EMCustomerCallBOD.ERPCall")
		|* Mandatory protected attribute %1$s is not set.
		dal.set.context(hold.context)
		return(DALHOOKERROR)
	endif

	set.permission.for.readonly.attributes(true)

	retl = Read.Object.EMCustomerCallBOD.tsclm100_1()
	if retl <> 0 then
		dal.set.context(hold.context)
		return(retl)
	endif
	set.current.number.of.DAL.messages()
	retl = Read.Object.EMCustomerCallBOD.tsclm105_2()
	if retl <> 0 then
		dal.set.context(hold.context)
		return(retl)
	endif
	clear.recent.DAL.error.messages()


|*	RETIFNOKINITFIN_COMPONENT(Read, EMCustomerCallBOD, "txclm.bl900sf00.after.Read.EMCustomerCallBOD")

	bl.EMCustomerCallBOD.initialize = false
	bl.ret = txclm.bl900st00.finalize.Read()
	dal.set.context(hold.context)

	return(0)
}

function extern 
long txclm.bl900st00.execute.EMCustomerCallBOD.Read.Only()
{
	DllUsage
	EndDllUsage

	long	result
	long	hold.context

	result = 0
	hold.context = dal.get.context()
	dal.set.context(CTX_INTEGRATION)
	set.current.number.of.DAL.messages()
	
	result = dal.get.object("tsclm100", false
		,"tsclm100.ccll", bl.EMCustomerCallBOD.CustomerCallHeader_DisplayID
		)
	if result <> 0 then
		clear.recent.DAL.error.messages()
		dal.set.context(hold.context)
		return(result)
	endif

	clear.recent.DAL.error.messages()
	dal.set.context(hold.context)
	return(0)
}

