#context_off
#context_on "HOOK:onGetHook; ATTRIBUTE:EMCustomerCallBOD.CustomerCallHeader_Status_Code"
function long Hook.OnGet.EMCustomerCallBOD.CustomerCallHeader_Status_Code(
		domain	tcyesno	i.ERPBlocked,
		boolean			i.ERPBlocked.isSet,
		domain	tsclm.stat	i.ERPStatus,
		boolean			i.ERPStatus.isSet,
	ref domain	tcmcs.str25	o.CustomerCallHeader_Status_Code,
	ref boolean	io.CustomerCallHeader_Status_Code.isSet)
{
io.CustomerCallHeader_Status_Code.isSet = true

if tcbod.dll0038.object.being.deleted() and
	   i.ERPStatus <> tsclm.stat.accept then
		o.CustomerCallHeader_Status_Code = STATUS_DELETED
	else
		if i.ERPBlocked = tcyesno.yes then
			o.CustomerCallHeader_Status_Code = STATUS_HOLD
		else
			on case i.ERPStatus
			case tsclm.stat.regist:
				o.CustomerCallHeader_Status_Code = STATUS_OPEN
				break
			case tsclm.stat.assign:
				o.CustomerCallHeader_Status_Code = STATUS_ASSIGNED
				break
			case tsclm.stat.process:
				o.CustomerCallHeader_Status_Code = STATUS_INPROCESS
				break
			case tsclm.stat.transf:
				o.CustomerCallHeader_Status_Code = STATUS_TRANSFERRED
				break
			case tsclm.stat.solved:
				o.CustomerCallHeader_Status_Code = STATUS_SOLVED
				break
			case tsclm.stat.accept:
				o.CustomerCallHeader_Status_Code = STATUS_ACCEPTED
				break
			endcase
		endif
	endif

	return(0)
		
}
#context_off
#context_on "HOOK:onGetHook; ATTRIBUTE:EMCustomerCallBOD.CustomerCallHeader_Status_ReasonCode"
function long Hook.OnGet.EMCustomerCallBOD.CustomerCallHeader_Status_ReasonCode(
		domain	tsopcv.c	i.CustomerCallHeader_ActionCodeValue,
		boolean			i.CustomerCallHeader_ActionCodeValue.isSet,
		domain	tcitem	i.CustomerCallHeader_Item,
		boolean			i.CustomerCallHeader_Item.isSet,
		domain	tcibd.sern	i.CustomerCallHeader_SerialNumber,
		boolean			i.CustomerCallHeader_SerialNumber.isSet,
		domain	tsclm.cprl	i.ERPReportedProblem,
		boolean			i.ERPReportedProblem.isSet,
	ref domain	tcmcs.st80m	o.CustomerCallHeader_Status_ReasonCode,
	ref boolean	io.CustomerCallHeader_Status_ReasonCode.isSet)
{
io.CustomerCallHeader_Status_ReasonCode.isSet = true

	domain	tsclm.cprl check.cprl1
	domain	tscfg.sigr sigr1
	
	o.CustomerCallHeader_Status_ReasonCode = ""
	if not isspace(i.CustomerCallHeader_ActionCodeValue) then
		|* Fetch Sigr
		txcom.dll9002.get.serialized.item.group(i.CustomerCallHeader_Item, i.CustomerCallHeader_SerialNumber, sigr1)
		check.cprl1 = "9999999999"
		
		select	tsclm905.*
		from	tsclm905
		where	tsclm905.sigr = {:sigr1}
		and	(tsclm905.cprl = {:i.ERPReportedProblem}
		or	tsclm905.cprl = {:check.cprl1} 
		or	tsclm905.cprl = "")
		and	tsclm905.opcv.c = {:i.CustomerCallHeader_ActionCodeValue}
		as set with 1 rows
		selectdo
			o.CustomerCallHeader_Status_ReasonCode = tsclm905.sear.c
			io.CustomerCallHeader_Status_ReasonCode.isSet = true
		endselect
	endif
	
	return(0)
}
