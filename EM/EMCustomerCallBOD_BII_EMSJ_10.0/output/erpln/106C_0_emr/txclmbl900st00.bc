}

function extern void txclm.bl900st00.init.paging()
{
	bl.SwitchDirection=false
	if bl.Len.EMCustomerCallBOD.tsclm100 = 0 then
		db.row.length(tbl.ttsclm100,bl.Len.EMCustomerCallBOD.tsclm100)
		alloc.mem(bl.First.EMCustomerCallBOD.tsclm100,bl.Len.EMCustomerCallBOD.tsclm100)
		set.mem(bl.First.EMCustomerCallBOD.tsclm100,"")
		alloc.mem(bl.NextFirst.EMCustomerCallBOD.tsclm100,bl.Len.EMCustomerCallBOD.tsclm100)
		set.mem(bl.NextFirst.EMCustomerCallBOD.tsclm100,"")
	endif
}

