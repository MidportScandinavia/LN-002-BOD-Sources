function boolean column.tsclm105.acco.element.exists(long i.element.nr)
{
	static	boolean	initialized	| whether this method was called before
	static	long	existing.dimensions		| the number of existing dimensions for the column
							| in the current application version; 0 if column does not exist
			long	depth	| depth for array column
	
	if not initialized then
		depth = column.exists("tsclm105", "acco")
		if depth > 0 then
			existing.dimensions = min(3, depth)	
		else
			existing.dimensions = 0
		endif

		initialized = true
	endif
	return(i.element.nr > 0 and i.element.nr <= existing.dimensions)
}

function boolean column.tsclm105.acco.element.changed(double i.value, long i.element.nr)
{
	double	value	| current value of field
	long	retl	| return value to be checked
	
	retl = get.indexed.var(pid, "tsclm105.acco", value, i.element.nr)
	if retl <> 0 then
		return(false)
	endif
	return(double.cmp(value, i.value, 0.000001) <> 0)
}

