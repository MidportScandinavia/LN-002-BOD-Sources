function extern
long txclm.bl900st00.initialize.EMCustomerCallBOD.Show()
{
	DllUsage
	EndDllUsage

static	long	hold.sapb.sql.pointer
	long	i

    if not bl.performing.ShowAndPublishBOD or hold.sapb.sql.pointer = 0 then
	build.select.for.EMCustomerCallBOD(false)
	build.from.for.EMCustomerCallBOD()
	if isspace(bl.from.EMCustomerCallBOD) then
		bl.sql.pointer.EMCustomerCallBOD = 0
		return(0)
	endif
	build.where.for.EMCustomerCallBOD()
	add.show.condition.to.where.EMCustomerCallBOD()
	RETIFNOK(build.orderby.for.EMCustomerCallBOD(true)) | suppress order by
	
	SET.ERROR.BYPASS.ON()
	bl.sql.pointer.EMCustomerCallBOD = sql.parse.mle(combine.query.EMCustomerCallBOD(), PARSE.DIALECT.6 + PARSE.SUPPRESS)
	SET.ERROR.BYPASS.OFF()
	if bl.performing.ShowAndPublishBOD then
		| store the SQL pointer for next time
		hold.sapb.sql.pointer = bl.sql.pointer.EMCustomerCallBOD
	endif
    else
	| restore the SQL pointer from previous time
	bl.sql.pointer.EMCustomerCallBOD = hold.sapb.sql.pointer
    endif
	bl.fetches.EMCustomerCallBOD = 0
	if bl.sql.pointer.EMCustomerCallBOD <= 0 then
		if MESSAGE_EXISTS("tlbcts0084") then
			dal.set.error.message("tlbcts0084", e, "EMCustomerCallBOD", "Show")
			|* Error %1$d in parsing of query for component %2$s in method %3$s
		else
			dal.set.error.message("@Error %d in parsing of query for component EMCustomerCallBOD in method Show", e)
		endif
		bl.EMCustomerCallBOD.query.status = QUERY.ERROR
		return (e)
	endif

	for i = 1 to bl.select.bind.counter.EMCustomerCallBOD
		RETIFNOK(bind.selection.EMCustomerCallBOD(i))
	endfor

	bl.EMCustomerCallBOD.query.status = QUERY.INIT
	
	return (0)
}

