|* ****** Batch method: EMCustomerCallBOD.OnProcess ******

function extern 
long txclm.bl900st00.execute.EMCustomerCallBOD.OnProcess(
						long	i.request, 
					ref	long	o.response, 
					ref	long	o.result)
{
	DllUsage
	EndDllUsage
	boolean	io.cancel
	boolean	loc.default
	long	retl

	| Reset io.cancel
	io.cancel = false
	retl = Hook.BeforeExecute.EMCustomerCallBOD.OnProcess(
					i.request, io.cancel)
	RETIFNOK(retl)
	if io.cancel then
		| Set result to 0
		o.result = 0

		| Create an empty response
		o.response = xmlNewNode("OnProcessResponse", XML_ELEMENT)
		return(0)
	endif
	loc.default = false
	RETIFNOK(Hook.OnExecute.EMCustomerCallBOD.OnProcess(
		i.request, o.response, o.result))
	retl = Hook.AfterExecute.EMCustomerCallBOD.OnProcess(
									i.request, o.response, o.result)
	RETIFNOK(retl)
	return(0)
}	
|* ****** Batch method: EMCustomerCallBOD.PublishEvent ******

function extern 
long txclm.bl900st00.execute.EMCustomerCallBOD.PublishEvent(
						long	i.request, 
					ref	long	o.response, 
					ref	long	o.result)
{
	DllUsage
	EndDllUsage
	long	loc.metaData
	long	duml
	long	retl

		| Create meta data node containing info on generated library and function name
		retl = tlbct.dll1000.CreateMetaDataNode(
						"otxclmbl900sb00", "txclm.bl900sb00.", 
						"otxclmbl900st00", "txclm.bl900st00.",
					loc.metaData,
					o.result,
						"bod")
		if retl <> 0 then
			dal.set.error.message("tlbctstgen", "PublishEvent",
					"EMCustomerCallBOD", "EMCustomerCallBOD")
			|* Error occurred in method '%1$s' on component '%2$s' of object '%3$s'
			| this message will be added to existing result in sb
			if o.response <> 0 then
				duml = xmlDelete(o.response)
				o.response = 0
			endif
		endif

		| Call the default execute for PublishEvent
		retl = tlbct.dll1000.DefaultOnExecute.PublishBOD(
					"EMCustomerCallBOD",
					"EMCustomerCall",
					loc.metaData,
					i.request, o.response, o.result)
		| Cleanup meta data information
		duml = xmlDelete(loc.metaData)
		loc.metaData = 0

		RETIFNOK(retl)
	return(0)
}	

