  <AttributeImplementation id="biiSJEquipmentInstallDismantleBOD-compSJEquipmentInstallDismantle-attrEquipmentID">
    <name>EquipmentID</name>
    <attribute idref="SJEquipmentInstallDismantleBOD_BID.bi#bidSJEquipmentInstallDismantle0-compSJEquipmentInstallDismantle-attrEquipmentID">EquipmentID</attribute>
    <type>column</type>
    <isIdentifier>false</isIdentifier>
    <isMandatory>false</isMandatory>
    <isReadOnly>false</isReadOnly>
    <afterGetHookExpression>&#x9;select&#x9;tscfg210.*&#xD;&#xA;&#x9;from&#x9;tscfg210&#xD;&#xA;&#x9;where&#x9;tscfg210._index2 = {:i.Item,:i.SerialNumber}&#xD;&#xA;&#x9;and   &#x9;tscfg210.cdf_dism = {&quot;Dismantle&quot;}&#xD;&#xA;&#x9;order by tscfg210.sttm desc&#xD;&#xA;&#x9;as set with 1 rows&#xD;&#xA;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.BreakdownStatus = tscfg210.stat&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ValidFromDate = tscfg210.sttm&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Position = tscfg210.lcid&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ServiceOrder = tscfg210.cdf_orno&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ActivityNumber = tscfg210.cdf_acln&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.VehiclePosition = tscfg210.cdf_cloc&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.SeverityCode = 0&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Note = &quot;&quot;&#xD;&#xA;&#x9;|&#x9;bl.SJEquipmentInstallDismantleBOD.ResultCode =&#x9;str$(tscfg215.cdf_lino)&#x9;&#x9;|#EMSJ_1012_002.n&#x9;|#EMSJ_1012_009.o&#x9;&#x9;|* Material Line&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ResultCode = str$(tscfg210.cdf_lino)&#x9;&#x9;|#EMSJ_1012_002.n&#x9;|#EMSJ_1012_009.n&#x9;&#x9;|* Material Line&#xD;&#xA;|#EMSJ_1012_004.sn&#xD;&#xA;&#x9;&#x9;if not isspace(tscfg210.pitm) and not isspace(tscfg210.pser) then&#xD;&#xA;&#x9;&#x9;&#x9;select&#x9;tscfg200.cdf_giai, tscfg200.cdf_evne&#xD;&#xA;&#x9;&#x9;&#x9;from&#x9;tscfg200&#xD;&#xA;&#x9;&#x9;&#x9;where&#x9;tscfg200._index1 = {:tscfg210.pitm, :tscfg210.pser}&#xD;&#xA;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg200.cdf_evne) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.FunctionalLocationID = tscfg200.cdf_evne&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;else&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg200.cdf_giai) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.SuperiorEquipmentID = tscfg200.cdf_giai&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;endif&#xD;&#xA;|#EMSJ_1012_004.en&#xD;&#xA;|#EMSJ_1012_009.sn&#xD;&#xA;&#x9;&#x9;if not isspace(tscfg210.cdf_orno) and tscfg210.cdf_acln &lt;> 0 then&#xD;&#xA;&#x9;&#x9;&#x9;select&#x9;tssoc210.*&#xD;&#xA;&#x9;&#x9;&#x9;from&#x9;tssoc210&#xD;&#xA;&#x9;&#x9;&#x9;where&#x9;tssoc210._index1 = {:tscfg210.cdf_orno,:tscfg210.cdf_acln}&#xD;&#xA;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.WorkOrderID = tssoc210.cdf_word&#xD;&#xA;&#x9;&#x9;endif&#xD;&#xA;|#EMSJ_1012_009.en&#xD;&#xA;&#x9;selectempty&#xD;&#xA;&#x9;&#x9;select&#x9;tscfg215.*&#xD;&#xA;&#x9;&#x9;from&#x9;tscfg215&#xD;&#xA;&#x9;&#x9;where&#x9;tscfg215._index2 = {:i.Item,:i.SerialNumber}&#xD;&#xA;&#x9;&#x9;order by tscfg215.lgtm desc&#xD;&#xA;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.BreakdownStatus = tscfg215.stat&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ValidFromDate = tscfg215.ettm&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Position = tscfg215.lcid&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ServiceOrder = tscfg215.cdf_orno&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ActivityNumber = tscfg215.cdf_acln&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.SeverityCode = tscfg215.cdf_serv&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Note = tscfg215.cdf_note&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.VehiclePosition = tscfg215.cdf_cloc&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ResultCode = str$(tscfg215.cdf_lino)&#x9;&#x9;|#EMSJ_1012_002.n&#x9;&#x9;|* Material Line&#x9;&#x9;&#xD;&#xA;|#EMSJ_1012_004.sn&#xD;&#xA;&#x9;&#x9;&#x9;if not isspace(tscfg215.pitm) and not isspace(tscfg215.pser) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;select&#x9;tscfg200.cdf_giai, tscfg200.cdf_evne&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;from&#x9;tscfg200&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;where&#x9;tscfg200._index1 = {:tscfg215.pitm, :tscfg215.pser}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg200.cdf_evne) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.FunctionalLocationID = tscfg200.cdf_evne&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;else&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg200.cdf_giai) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.SuperiorEquipmentID = tscfg200.cdf_giai&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;endif&#xD;&#xA;|#EMSJ_1012_004.en&#xD;&#xA;|#EMSJ_1012_009.sn&#xD;&#xA;&#x9;&#x9;&#x9;if not isspace(tscfg215.cdf_orno) and tscfg215.cdf_acln &lt;> 0 then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;select&#x9;tssoc210.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;from&#x9;tssoc210&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;where&#x9;tssoc210._index1 = {:tscfg215.cdf_orno,:tscfg215.cdf_acln}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.WorkOrderID = tssoc210.cdf_word&#xD;&#xA;&#x9;&#x9;&#x9;endif&#xD;&#xA;|#EMSJ_1012_009.en&#xD;&#xA;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;if ((tscfg215.cdf_serv = 1 or tscfg215.cdf_serv = 2) and etol(tscfg215.stat) = 20) or install_publish = &quot;9&quot;  then &#xD;&#xA;&#x9;&#x9;&#x9;select&#x9;tscfg215.*&#xD;&#xA;&#x9;&#x9;&#x9;from&#x9;tscfg215&#xD;&#xA;&#x9;&#x9;&#x9;where&#x9;tscfg215._index2 = {:i.Item,:i.SerialNumber}&#xD;&#xA;&#x9;&#x9;&#x9;and&#x9;tscfg215.stat = 10&#xD;&#xA;&#x9;&#x9;&#x9;order by tscfg215.lgtm desc&#xD;&#xA;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.BreakdownStatus = tscfg215.stat&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ValidFromDate = tscfg215.ettm&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Position = tscfg215.lcid&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ServiceOrder = tscfg215.cdf_orno&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ActivityNumber = tscfg215.cdf_acln&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.SeverityCode = tscfg215.cdf_serv&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Note = tscfg215.cdf_note&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.VehiclePosition = tscfg215.cdf_cloc&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.ResultCode = str$(tscfg215.cdf_lino)&#x9;&#x9;|#EMSJ_1012_002.n&#x9;&#x9;|* Material Line&#x9;&#xD;&#xA;|#EMSJ_1012_004.sn&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg215.pitm) and not isspace(tscfg215.pser) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;select&#x9;tscfg200.cdf_giai, tscfg200.cdf_evne&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;from&#x9;tscfg200&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;where&#x9;tscfg200._index1 = {:tscfg215.pitm, :tscfg215.pser}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg200.cdf_evne) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.FunctionalLocationID = tscfg200.cdf_evne&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;else&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg200.cdf_giai) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.SuperiorEquipmentID = tscfg200.cdf_giai&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;|#EMSJ_1012_004.en&#x9;&#x9;&#xD;&#xA;|#EMSJ_1012_009.sn&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;if not isspace(tscfg215.cdf_orno) and tscfg215.cdf_acln &lt;> 0 then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;select&#x9;tssoc210.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;from&#x9;tssoc210&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;where&#x9;tssoc210._index1 = {:tscfg215.cdf_orno,:tscfg215.cdf_acln}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.WorkOrderID = tssoc210.cdf_word&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;|#EMSJ_1012_009.en&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;endif&#xD;&#xA;&#x9;endselect&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;return(0)</afterGetHookExpression>
