    <onGetHookExpression>&#x9;o.StorageLocation = &quot;&quot;&#xD;&#xA;&#x9;select&#x9;tscfg210.*&#xD;&#xA;&#x9;from&#x9;tscfg210&#xD;&#xA;&#x9;where&#x9;tscfg210._index2 = {:i.Item,:i.SerialNumber}&#xD;&#xA;&#x9;and   &#x9;tscfg210.cdf_dism = {&quot;Dismantle&quot;}&#xD;&#xA;&#x9;order by tscfg210.sttm desc&#xD;&#xA;&#x9;as set with 1 rows&#xD;&#xA;&#x9;selectdo&#xD;&#xA;&#x9;|&#x9;select&#x9;tssoc220.awrh, tssoc220.lino&#xD;&#xA;&#x9;&#x9;select&#x9;tssoc220.*&#xD;&#xA;&#x9;&#x9;from&#x9;tssoc220&#xD;&#xA;&#x9;&#x9;where&#x9;tssoc220.orno = {:tscfg210.cdf_orno}&#xD;&#xA;&#x9;&#x9;and&#x9;tssoc220.acln = {:tscfg210.cdf_acln}&#xD;&#xA;&#x9;&#x9;and&#x9;tssoc220.item = {:i.Item}&#xD;&#xA;&#x9;&#x9;and&#x9;tssoc220.sern = {:i.SerialNumber}&#xD;&#xA;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Lot = str$(tssoc220.lino)&#xD;&#xA;&#x9;&#x9;if tssoc220.dltp = tsmdm.dltp.to.scrap or tssoc220.dltp = tsmdm.dltp.from.serv.inv then&#x9;&#x9;|#EMSJ_1012_003.sn&#xD;&#xA;&#x9;&#x9;&#x9;if not isspace(tssoc220.cdf_cwar) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;select&#x9;tsmdm903.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;from&#x9;tsmdm903&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;where&#x9;tsmdm903.warh.c = {:tssoc220.cdf_cwar}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;else&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;|#EMSJ_1012_003.en&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;&#x9;if not isspace(tssoc220.awrh) then&#xD;&#xA;&#x9;&#x9;&#x9;|&#x9;select&#x9;tsmdm903.sjwh.c:o.StorageLocation&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;select&#x9;tsmdm903.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;from&#x9;tsmdm903&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;where&#x9;tsmdm903.warh.c = {:tssoc220.awrh}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;|&#x9;&#x9;o.StorageLocation = tsmdm903.sjwh.c&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;endif&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;|#EMSJ_1012_003.n&#xD;&#xA;&#x9;&#x9;o.StorageLocation = tsmdm903.sjwh.c&#xD;&#xA;&#x9;|&#x9;endselect&#xD;&#xA;&#x9;selectempty&#xD;&#xA;&#x9;&#x9;select&#x9;tscfg215.*&#xD;&#xA;&#x9;&#x9;from&#x9;tscfg215&#xD;&#xA;&#x9;&#x9;where&#x9;tscfg215._index2 = {:i.Item,:i.SerialNumber}&#xD;&#xA;&#x9;&#x9;order by tscfg215.lgtm desc&#xD;&#xA;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;|&#x9;select&#x9;tssoc220.awrh, tssoc220.lino&#xD;&#xA;&#x9;&#x9;&#x9;select&#x9;tssoc220.*&#xD;&#xA;&#x9;&#x9;&#x9;from&#x9;tssoc220&#xD;&#xA;&#x9;&#x9;&#x9;where&#x9;tssoc220.orno = {:tscfg210.cdf_orno}&#xD;&#xA;&#x9;&#x9;&#x9;and&#x9;tssoc220.acln = {:tscfg210.cdf_acln}&#xD;&#xA;&#x9;&#x9;&#x9;and&#x9;tssoc220.item = {:i.Item}&#xD;&#xA;&#x9;&#x9;&#x9;and&#x9;tssoc220.sern = {:i.SerialNumber}&#xD;&#xA;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Lot = str$(tssoc220.lino)&#xD;&#xA;&#x9;&#x9;&#x9;if tssoc220.dltp = tsmdm.dltp.to.scrap or tssoc220.dltp = tsmdm.dltp.from.serv.inv then&#x9;&#x9;|#EMSJ_1012_003.sn&#xD;&#xA;&#x9;&#x9;&#x9;if not isspace(tssoc220.cdf_cwar) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;select&#x9;tsmdm903.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;from&#x9;tsmdm903&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;where&#x9;tsmdm903.warh.c = {:tssoc220.cdf_cwar}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;else&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;|#EMSJ_1012_003.en&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;if not isspace(tssoc220.awrh) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;|&#x9;select&#x9;tsmdm903.sjwh.c:o.StorageLocation&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;select&#x9;tsmdm903.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;from&#x9;tsmdm903&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;where&#x9;tsmdm903.warh.c = {:tssoc220.awrh}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;|&#x9;o.StorageLocation = tsmdm903.sjwh.c&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;endif&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;|#EMSJ_1012_003.n&#xD;&#xA;&#x9;&#x9;&#x9;o.StorageLocation = tsmdm903.sjwh.c&#xD;&#xA;&#x9;&#x9;|&#x9;endselect&#xD;&#xA;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#xD;&#xA;&#x9;&#x9;if ((tscfg215.cdf_serv = 1 or tscfg215.cdf_serv = 2) and etol(tscfg215.stat) = 20) or install_publish = &quot;9&quot; then &#xD;&#xA;&#x9;&#x9;&#x9;select&#x9;tscfg215.*&#xD;&#xA;&#x9;&#x9;&#x9;from&#x9;tscfg215&#xD;&#xA;&#x9;&#x9;&#x9;where&#x9;tscfg215._index2 = {:i.Item,:i.SerialNumber}&#xD;&#xA;&#x9;&#x9;&#x9;and&#x9;tscfg215.stat = 10&#xD;&#xA;&#x9;&#x9;&#x9;order by tscfg215.lgtm desc&#xD;&#xA;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;|&#x9;select&#x9;tssoc220.awrh, tssoc220.lino &#xD;&#xA;&#x9;&#x9;&#x9;&#x9;select&#x9;tssoc220.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;from&#x9;tssoc220&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;where&#x9;tssoc220.orno = {:tscfg210.cdf_orno}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;and&#x9;tssoc220.acln = {:tscfg210.cdf_acln}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;and&#x9;tssoc220.item = {:i.Item}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;and&#x9;tssoc220.sern = {:i.SerialNumber}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;bl.SJEquipmentInstallDismantleBOD.Lot = str$(tssoc220.lino)&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;if tssoc220.dltp = tsmdm.dltp.to.scrap or tssoc220.dltp = tsmdm.dltp.from.serv.inv then&#x9;&#x9;|#EMSJ_1012_003.sn&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if not isspace(tssoc220.cdf_cwar) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;select&#x9;tsmdm903.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;from&#x9;tsmdm903&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;where&#x9;tsmdm903.warh.c = {:tssoc220.cdf_cwar}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;else&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;|#EMSJ_1012_003.en&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if not isspace(tssoc220.awrh) then&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;|&#x9;select&#x9;tsmdm903.sjwh.c:o.StorageLocation&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;select&#x9;tsmdm903.*&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;from&#x9;tsmdm903&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;where&#x9;tsmdm903.warh.c = {:tssoc220.awrh}&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;as set with 1 rows&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;selectdo&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;|&#x9;&#x9;o.StorageLocation = tsmdm903.sjwh.c&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;endif&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;endif&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;|#EMSJ_1012_003.n&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;o.StorageLocation = tsmdm903.sjwh.c&#xD;&#xA;&#x9;&#x9;&#x9;|&#x9;endselect&#xD;&#xA;&#x9;&#x9;&#x9;endselect&#xD;&#xA;&#x9;&#x9;endif&#xD;&#xA;&#x9;endselect&#x9;&#xD;&#xA;&#x9;&#xD;&#xA;&#x9;io.StorageLocation.isSet = true&#xD;&#xA;&#x9;return(0)</onGetHookExpression>
