function long SetSelectionVariable_new1(const string SelecVar)
{
	long	end_pos_comp
	boolean	correct_selection

	correct_selection = false
	|* Strip component.
	end_pos_comp = pos(SelecVar, ".")

	if end_pos_comp > 0 then
		on case SelecVar(1;end_pos_comp-1)
		case "SJEquipmentInstallDismantleBOD":
			SetSelectionVariable_New1_SJEquipmentInstallDismantleBOD(
				SelecVar(end_pos_comp+1), correct_selection)
			break
		endcase
	else
		if SelecVar = "*" then
			InitSelection(true)
			correct_selection = true
		endif
	endif
	
	if not correct_selection then
			dal.set.error.message("tlbctsb0042", SelecVar)
			|* No valid selectionAttributes received
			|* (unknown selectionAttribute received "%1$s").
			return(DALHOOKERROR)
	endif
	return (0)
}

	     
