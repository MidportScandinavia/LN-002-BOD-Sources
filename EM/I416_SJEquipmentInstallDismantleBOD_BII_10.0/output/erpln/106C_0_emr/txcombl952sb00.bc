	long	l, conv, retv
	temp.value = i.value
	retv = rdi.domain.string( "tcmcs.str50m", l, conv )
	on case conv
	case RDI.UPPER:
		temp.value = toupper$(temp.value)
		break
	case RDI.LOWER:
		temp.value = tolower$(temp.value)
		break
	case RDI.NONE:
	endcase
	RETIFNOK(tlbct.dll1000.domain.check.value(temp.value,
		"tcmcs.str50m", "tcmcs.str50m", "BODID_ExternalReferenceID"))
	l.BODID_ExternalReferenceID = temp.value
	retv = tt.align.according.domain(l.BODID_ExternalReferenceID, l.BODID_ExternalReferenceID, "tcmcs.str50m")
