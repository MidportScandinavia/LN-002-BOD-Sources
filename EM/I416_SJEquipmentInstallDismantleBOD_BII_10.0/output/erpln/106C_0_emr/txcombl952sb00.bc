function long SetSelection_new1(xmlNode SelectionNode)
{
	long	ret
	xmlNode	AttributeNode
	string	SelectionAttribute(256)
	boolean	postfilter
	xmlnode filteredAttributes
	xmlnode	filter.attribute

	AttributeNode = xmlGetFirstChild(SelectionNode)
	while AttributeNode <> 0
		ret = xmlGetData(AttributeNode, SelectionAttribute)
		RETIFNOK(SetSelectionVariable_new1(strip$(SelectionAttribute)))
		AttributeNode = xmlGetRightSibling(AttributeNode)
	endwhile
	
	|* Set selected for postfilter attributes
	RETIFNOK(txcom.bl952st00.get.postfilter(postfilter))
	if postfilter then
		RETIFNOK(txcom.bl952st00.get.filteredAttributes(
					filteredAttributes))
		filter.attribute = xmlGetFirstChild(filteredAttributes)
		while filter.attribute <> 0
			on case xmlData$(filter.attribute)
			case "SJEquipmentInstallDismantleBOD.BODID_ExternalReferenceID":
				SJEquipmentInstallDismantleBOD.BODID_ExternalReferenceID.select = true
				break
			case "SJEquipmentInstallDismantleBOD.UUID":
				SJEquipmentInstallDismantleBOD.UUID.select = true
				break
			case "SJEquipmentInstallDismantleBOD.EquipmentID":
				SJEquipmentInstallDismantleBOD.EquipmentID.select = true
				break
			case "SJEquipmentInstallDismantleBOD.ActionCode":
