				break
			case "SJEquipmentInstallDismantleBOD.Material":
				SJEquipmentInstallDismantleBOD.Material.select = true
				break
			case "SJEquipmentInstallDismantleBOD.Lot":
				SJEquipmentInstallDismantleBOD.Lot.select = true
				break
