	long	bl.retval
	long	duml

	duml = 0
	bl.current.method = "Show"
	bl.processingScope = REQUEST
		
	RETIFNOK2(createResponseObject(o.ResponseArgument, "Show"))
	RETIFNOK2(createResultObject(o.ResultArgument))
	RETIFNOK2(selectResponseNode(o.ResponseArgument, ResponseSJEquipmentInstallDismantleBODNode))

	make.xmlArguments.global(i.RequestArgument,
				 o.ResponseArgument,
				 o.ResultArgument)
	txcom.bl952st00.initialize.tables()


	doFetch = true
	bl.result = Handle.Request.Show.SJEquipmentInstallDismantleBOD_new(i.RequestArgument, 
				o.ResponseArgument, o.ResultArgument,
				ResponseSJEquipmentInstallDismantleBODNode, SJEquipmentInstallDismantleBOD_cancel)

	bl.retval = bl.result
	if bl.result <> 0 then
		|* Add used query to response.
		add.executed.queries.to.response.Show.SJEquipmentInstallDismantleBOD(o.resultArgument, true)
		handle.messages(o.responseArgument,
		o.resultArgument,
		true)
        bl.ret = xmlDelete(o.ResponseArgument)
        o.ResponseArgument = 0
	else
	 	if log.query then
			|* Add used query to response.
			add.executed.queries.to.response.Show.SJEquipmentInstallDismantleBOD(o.ResponseArgument, false)
		endif
		handle.messages(o.ResponseArgument,
			o.ResultArgument, false) |* put mess in response
	endif
		RETIFNOK2_LIST_NEW(txcom.bl952st00.finalize.SJEquipmentInstallDismantleBOD.Show())
		
		RETIFNOK2_LIST_NEW(txcom.bl952st00.finalize.request.Show())

	return(bl.retval)
}

	     
function add.executed.queries.to.response.Show.SJEquipmentInstallDismantleBOD(xmlnode	io.response,
					boolean		i.error)
{
	xmlnode	log.node
	xmlnode mess.node
	xmlnode	curr.node
	long	i, ret
	xmlnode	bnode
	string hookname(128)
	string filterExpression(1024)
	boolean	postFilter
	xmlnode	filter

	if txcom.bl952st00.return.query.status.SJEquipmentInstallDismantleBOD() = QUERY.INACTIVE then
		return
	endif
	if i.error then
		| we cannot assume that the result is not empty or has no message details
		if xmlGetFirstChild(io.response) = 0 then
			mess.node = io.response
		else
			log.node = xmlFindFirstMatch("<>.<MessageDetails>", io.response)
			if log.node = 0 then
				log.node = xmlNewNode("MessageDetails", XML_ELEMENT, io.response)
			endif
		endif
	else
		log.node = xmlFindFirstMatch("<>.<InformationArea>", io.response)
		if log.node = 0 then
			log.node = xmlNewNode("InformationArea", XML_ELEMENT, io.response)
		endif
		mess.node = xmlNewNode("Message", XML_ELEMENT, log.node)
		ret = xmlSetAttribute(mess.node, "ID", "ID000001")
	endif

	curr.node = xmlNewDataElement("messageCode", "QueryLog", mess.node)
	curr.node = xmlNewDataElement("messageType", "Information", mess.node)
	curr.node = xmlNewDataElement("messageText", "Executed Queries for method Show.",
				mess.node)
	curr.node = xmlNewDataElement("messageSource","SQL Query",
				mess.node)
	mess.node = xmlNewNode("MessageReference", XML_ELEMENT, mess.node)
	curr.node = xmlNewDataElement("messageReferenceType", "logEntry", mess.node)
	curr.node = xmlNewNode("messageReferenceInfo", XML_ELEMENT, mess.node)
	for i = 1 to txcom.bl952st00.retrieve.table_alias.count()
		if i = 1 then
			mess.node = xmlNewNode("Table_Aliases",XML_ELEMENT, curr.node)
		endif
		bnode = xmlNewDataElement("t" & str$(i),
			strip$(txcom.bl952st00.retrieve.table_alias(i)), mess.node)
	endfor
	mess.node = xmlNewNode("ComponentFilterHook", XML_ELEMENT, curr.node)
	mess.node = xmlNewNode("Filter", XML_ELEMENT, curr.node)
	ret = txcom.bl952st00.get.filter.expression(filterExpression)
	bnode = xmlNewDataElement("Expression", filterExpression, mess.node)
	mess.node = xmlNewNode("PostFilter", XML_ELEMENT, curr.node)
	ret = txcom.bl952st00.get.postfilter(postfilter)
	if postfilter then
		|* for postfiltering the original filter is used
		ret = txcom.bl952st00.get.filter(filter)
		ret = xmlDuplicateAndAppendToChilds(mess.node, filter)
	endif
	ret = xmlSetAttribute(mess.node, "postfiltering", postfilter?"true":"false")

	log.node = xmlNewNode("SJEquipmentInstallDismantleBOD",XML_ELEMENT, curr.node)

	if txcom.bl952st00.query.on.hook.SJEquipmentInstallDismantleBOD.Show(hookname) then
	mess.node = xmlNewDataElement("HOOK", 
		"Query is executed in hook " & strip$(hookname), log.node)
	else
	|* Read and Add query.
	mess.node = xmlNewDataElement("select", 
		txcom.bl952st00.retrieve.select.clause.SJEquipmentInstallDismantleBOD(), log.node)
	mess.node = xmlNewDataElement("from", 
		txcom.bl952st00.retrieve.from.clause.SJEquipmentInstallDismantleBOD(), log.node)
	mess.node = xmlNewDataElement("where", 
		txcom.bl952st00.retrieve.where.clause.SJEquipmentInstallDismantleBOD(), log.node)
	mess.node = xmlNewDataElement("orderby", 
		txcom.bl952st00.retrieve.orderby.clause.SJEquipmentInstallDismantleBOD(), log.node)
	for i = 1 to txcom.bl952st00.retrieve.selectbind.count.SJEquipmentInstallDismantleBOD()
		if i = 1 then
			mess.node = xmlNewNode("selectbind",XML_ELEMENT, log.node)
		endif
		bnode = xmlNewDataElement("_" & str$(i),
			strip$(txcom.bl952st00.retrieve.selectbind.clause.SJEquipmentInstallDismantleBOD(i)), mess.node)
	endfor
	for i = 1 to txcom.bl952st00.retrieve.wherebind.count.SJEquipmentInstallDismantleBOD()
		if i = 1 then
			mess.node = xmlNewNode("wherebind",XML_ELEMENT, log.node)
		endif
		bnode = xmlNewDataElement("_"& str$(i),
			strip$(txcom.bl952st00.retrieve.wherebind.clause.SJEquipmentInstallDismantleBOD(i)), mess.node)
	endfor
	endif
	if txcom.bl952st00.return.query.status.SJEquipmentInstallDismantleBOD() = QUERY.ERROR then
		ret = xmlsetAttribute(log.node, "Error_status", "Error")
		return
	endif
	ret = xmlsetAttribute(log.node, "fetches", txcom.bl952st00.retrieve.fetch.count.SJEquipmentInstallDismantleBOD())
	
	|* Add sub components.
}

	     
function long Handle.Request.Show.SJEquipmentInstallDismantleBOD_new(
			const		xmlNode	i.RequestSJEquipmentInstallDismantleBODNode,
			ref			xmlNode	io_Show.ResponseArgument, 
			ref			xmlNode	io_Show.ResultArgument,
			const		xmlNode	i.ResponseSJEquipmentInstallDismantleBODNode,
			ref		boolean	o.cancel)
{
	long	ret
	boolean	fetching
	xmlNode	Response.SJEquipmentInstallDismantleBODNode
	boolean	selection.present
	xmlnode	ControlAreaNode
	long	fetch.count
	boolean sortingExpressionSet
	boolean	TagFound
	string  Value(1024)
	xmlnode	filter
	boolean	postfilter
	xmlnode	metaDataForFilter
	boolean	postfilter.valid

	ret = 0
	bl.result = 0
	Response.SJEquipmentInstallDismantleBODNode = 0

	ControlAreaNode = xmlFindFirst("ControlArea", i.RequestSJEquipmentInstallDismantleBODNode)
	if txcom.bl952st00.return.query.status.SJEquipmentInstallDismantleBOD() <> QUERY.FETCH then
		RETIFNOK5_LIST(txcom.bl952st00.initialize.request.Show())
	endif
	|* Get sortingExpression from the ControlAreaNode Node
	RETIFNOK6_LIST(getValue(ControlAreaNode, 
			"ControlArea.sortingExpression",
			"<ControlArea>.<sortingExpression>",
			false, Value, TagFound),
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())
	if Tagfound then
		if not isspace(Value) then
			dal.set.error.message("tlbctsb0050")
			|* No valid sortingExpression received
			|* (a non-empty sortingExpression is not supported).
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show()
			return(DALHOOKERROR)					
		endif
		sortingExpressionSet = true
	else
		sortingExpressionSet = false
	endif
	
	|* Set sortingExpression to protected layer
	RETIFNOK6_LIST(txcom.bl952st00.set.sorting.expression(sortingExpressionSet),
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())

	|* Set filter to protected layer and determine postfiltering
	filter = xmlFindFirst("Filter", ControlAreaNode)
	RETIFNOK5_LIST(txcom.bl952st00.set.request.filter(filter))

	|* Get list of components with parent components
	RETIFNOK5_LIST(txcom.bl952st00.get.postfilter(postfilter))								
	if postfilter then	
		metaDataForFilter = Show.getMetaDataForFilter()
	endif

	CONTINUEIFNOK(Show,
			io_Show.ResponseArgument, io_Show.ResultArgument,
			"SJEquipmentInstallDismantleBOD", "SJEquipmentInstallDismantleBOD", false,
			Show.handle.input.SJEquipmentInstallDismantleBOD_new(i.RequestSJEquipmentInstallDismantleBODNode,
			io_Show.ResponseArgument, io_Show.ResultArgument,
			selection.present))
	if not selection.present then	|* No valid selection attributes found
		return(0)
	endif
	if txcom.bl952st00.return.query.status.SJEquipmentInstallDismantleBOD() <> QUERY.END then
		RETIFNOK5_LIST(txcom.bl952st00.initialize.SJEquipmentInstallDismantleBOD.Show())
	endif

	CONTINUEIFNOK(Show,
			io_Show.ResponseArgument, io_Show.ResultArgument,
			"SJEquipmentInstallDismantleBOD", "SJEquipmentInstallDismantleBOD", false,
			txcom.bl952st00.initialize.set.SJEquipmentInstallDismantleBOD.Show())
	fetching = true
	fetch.count = 0
	while fetching
		RETIFNOK6_LIST(
			txcom.bl952st00.before.execute.SJEquipmentInstallDismantleBOD.Show(o.cancel),
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())
		if o.cancel then
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show()
			return(0)
		endif

		RETIFNOK6_LIST(
			txcom.bl952st00.execute.SJEquipmentInstallDismantleBOD.Show(),
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())

		on case txcom.bl952st00.return.query.status.SJEquipmentInstallDismantleBOD()
		case QUERY.FETCH:
			RETIFNOK6_LIST(
				Show.handle.output.SJEquipmentInstallDismantleBOD_new(0,
				Response.SJEquipmentInstallDismantleBODNode),
				txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())

			RETIFNOK6_LIST(tlbct.dll1000.ApplyPostFilter(
				postfilter,
				filter,
				metaDataForFilter,
				i.ResponseSJEquipmentInstallDismantleBODNode,
				Response.SJEquipmentInstallDismantleBODNode,
				postfilter.valid),
				txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())
			break
		case QUERY.END:
			fetching = false
			break
		case QUERY.ERROR:
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show()
			return (bl.result)
		default:
			|* Should not come here.
			fetching = false
			break
		endcase

		RETIFNOK6_LIST(
			txcom.bl952st00.after.execute.SJEquipmentInstallDismantleBOD.Show(),
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())
		if fetching and Response.SJEquipmentInstallDismantleBODNode <> 0 then
			fetch.count = fetch.count + 1
		endif
		fetching = false
	endwhile
	
		if fetch.count = 0 then
			| No objects lefts!
			dal.set.error.message("tlbctsb0026")
			|* Object not found.
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show()
			return(DALHOOKERROR)
		endif
		CONTINUEIFNOK(Show,
			io_Show.ResponseArgument, io_Show.ResultArgument,
			"SJEquipmentInstallDismantleBOD", "SJEquipmentInstallDismantleBOD", false,
			txcom.bl952st00.finalize.set.SJEquipmentInstallDismantleBOD.Show())
			
	return(0)
}

	     
