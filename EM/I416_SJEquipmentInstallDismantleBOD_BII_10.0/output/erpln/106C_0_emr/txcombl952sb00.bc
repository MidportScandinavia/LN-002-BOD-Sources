function void make.xmlArguments.global( const xmlNode i.RequestArgument,
					const xmlNode i.ResponseArgument,
					const xmlNode i.ResultArgument)
{
	bl.RequestArgument  = i.RequestArgument
	bl.ResponseArgument = i.ResponseArgument
	bl.ResultArgument   = i.ResultArgument
	|* Make request, response, result available in protected layer
	txcom.bl952st00.set.xmlArguments(i.RequestArgument,
		i.ResponseArgument, i.ResultArgument)
}

function boolean set.in.result(boolean i.inResult)
{
	on case bl.processingScope
	case BUS_ENT:
	case BUS_ENT_CMP:
		|* errors must be put into response.
		return (false)
	endcase
	return (i.inResult)
}

function long Handle.retrying.component(string	i.method(50),	
					string	i.bde(50),
					string	i.component(50),
					ref xmlNode o.ResponseArgument,
					ref xmlNode o.ResultArgument)
{
	if db.retry.hit() then
		abort.transaction()
	endif
	if db.retry.hit() > db.max.retry() - 2 then	|%To be saver
		if MESSAGE_EXISTS("tlbcts0082") then
			dal.set.error.message("tlbcts0082", db.max.retry(), strip$(i.method), strip$(i.component))
			|* Max number of retries (%1$d) reached in method %2$s in Component %3$s
		else
			dal.set.error.message("@Max number of retries ("&
				str$(db.max.retry()) & ") reached in method " &
				strip$(i.method) & " in Component " &
				strip$(i.component))
		endif
		bl.result = DALHOOKERROR
		handle.transactionScope(true,
			o.ResponseArgument, o.ResultArgument,
			i.method, i.bde, i.component)
		return (DALHOOKERROR)
	endif
	return (0)
}

function convert.xml.to.text(long TNode, const string TField, ref long TextNumber)
{
static	long	dll.id
static	long	func.id
	long	ret
	long	retval
	
	if func.id = 0 then
		dll.id = load_dll("otlbctdll1000")
		func.id = get_function(dll.id,
				"tlbct.dll1000.xmlimage.convert.xml.to.text")
	endif
	if func.id = 0 then
		ret = tlbct.dll1000.xmlimage.convert.xml.to.text(TNode, TextNumber)
	else
		ret = exec_function(dll.id, func.id, retval, TNode, TextNumber, true, TField)
	endif
}

	     
