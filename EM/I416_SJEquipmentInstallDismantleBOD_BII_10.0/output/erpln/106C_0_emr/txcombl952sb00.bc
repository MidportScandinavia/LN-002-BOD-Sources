function long txcom.bl952sb00.set.SJEquipmentInstallDismantleBOD.Error.Mapper(			
	const	string	i.value)				
{
	domain	tcyesno	l.Error

	long enum.long

	if isspace(i.value) then
		dal.set.error.message("tlbctsb0003", "SJEquipmentInstallDismantleBOD.Error")
		return(DALHOOKERROR)
	endif
	enum.long = rdi.ctoe("tcyesno", strip$(i.value))
	if enum.long < 1 then
		dal.set.error.message("tlbctsb0002", strip$(i.value),
			"tcyesno")
		return(DALHOOKERROR)
	endif
	l.Error = ltoe(enum.long)
	RETIFNOK(tlbct.dll1000.domain.check.value(i.value,
		"tcyesno", "tcyesno", "Error"))
	RETIFNOK(txcom.bl952st00.set.SJEquipmentInstallDismantleBOD.Error(
			l.Error))
	return(0)
}

