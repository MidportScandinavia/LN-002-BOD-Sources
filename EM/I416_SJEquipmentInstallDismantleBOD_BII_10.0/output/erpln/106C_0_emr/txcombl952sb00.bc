	endif

	return(false)
}

  


function extern long txcom.bl952sb00.OnProcess(
					ref xmlNode i.RequestArgument,
					ref xmlNode o.ResponseArgument,
					ref xmlNode o.ResultArgument)
{
	DllUsage
		This method processes OnProcess events as requested in
		the XML Request message.
		If success, the XML Response is filled.
		Errors are put in the XML Result message.
	EndDllUsage

	CHECK_TOOLS_VERSION(o.ResponseArgument, o.ResultArgument)

	RETIFNOK2(txcom.bl952st00.execute.SJEquipmentInstallDismantleBOD.OnProcess(
						i.RequestArgument, o.ResponseArgument, o.ResultArgument))

	handle.messages(o.ResponseArgument,
			o.ResultArgument, false) |* put mess in response
	return(0)
}

