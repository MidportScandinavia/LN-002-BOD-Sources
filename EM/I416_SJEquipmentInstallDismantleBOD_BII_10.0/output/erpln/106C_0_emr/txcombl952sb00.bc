				SJEquipmentInstallDismantleBOD.MovementType.select = true
				break
			case "SJEquipmentInstallDismantleBOD.StorageLocation":
				SJEquipmentInstallDismantleBOD.StorageLocation.select = true
				break
			case "SJEquipmentInstallDismantleBOD.Position":
