|******************* customizations: extensions *******************************

function extern long txcom.bl952sb00.get.component.data(
	ref	long	o.xml)
{
	DllUsage
	Desc:	Gets all components with their tables.
	Input:	-
	Output:	o.xml - if return value is = 0: an xml structure containing
                        the components and tables.
	Return:	0 (OK) or <> 0 (error)
	EndDllUsage

	long	componentNode
	long	tableNode
	long	duml

	o.xml = xmlNewNode("ComponentsAndTables")
	componentNode = xmlNewNode("Component", XML_ELEMENT, o.xml)
	duml = xmlSetAttribute(componentNode, "Name", "SJEquipmentInstallDismantleBOD")
	duml = xmlSetAttribute(componentNode, "PublicPath", "SJEquipmentInstallDismantleBOD")
	duml = xmlSetAttribute(componentNode, "CustomDataElement", "UserArea")
	tableNode = xmlNewNode("Table", XML_ELEMENT, componentNode)
	duml = xmlSetAttribute(tableNode, "Name", "tscfg200")
	duml = xmlSetAttribute(componentNode, "RootTable", "tscfg200")
	return(0) | OK
}

function extern long txcom.bl952sb00.get.specific.component.data(
	const	string	i.publicPath,
	ref	long	o.xml)
{
	DllUsage
	Desc:	Gets all component specific data for a component.
	Input:	i.publicPath - the public path for the component
	Output:	o.xml - if return value is = 0: an xml structure containing
                        the tables for the component.
	Return:	0 (OK) or <> -1 (error: public path unknown)
	EndDllUsage

	long	tableNode
	long	duml

	on case i.publicPath
	case "SJEquipmentInstallDismantleBOD":
		o.xml = xmlNewNode("Component")
		duml = xmlSetAttribute(o.xml, "Name", "SJEquipmentInstallDismantleBOD")
		duml = xmlSetAttribute(o.xml, "CustomDataElement", "UserArea")
		tableNode = xmlNewNode("Table", XML_ELEMENT, o.xml)
		duml = xmlSetAttribute(tableNode, "Name", "tscfg200")
		duml = xmlSetAttribute(o.xml, "RootTable", "tscfg200")
		break
	default:
		| Public path unknown
		o.xml = 0
		return(-1)
	endcase
	return(0) | OK
}

|******************* customizations: generated part ***************************

function boolean are.all.present(long i.additional.elements, long i.customer.data)
{
	long	table.node
	long	element.node
	
	table.node = xmlGetFirstChild(i.additional.elements)
	while table.node <> 0
		element.node = xmlGetFirstChild(table.node)
		if xmlName$(table.node) = "Element" then
			if not is.present(xmlAttribute$(table.node, "name"), i.customer.data) then
				return(false)
			endif
		else
			element.node = xmlGetFirstChild(table.node)
			while element.node <> 0
				if not is.present(xmlData$(element.node), i.customer.data) then
					return(false)
				endif
				element.node = xmlGetRightSibling(element.node)
			endwhile
		endif
		table.node = xmlGetRightSibling(table.node)
	endwhile
	return(true)
}

function boolean is.present(const string i.name, long i.customer.data)
{
	long	name.value.node
	
	name.value.node = xmlGetFirstChild(i.customer.data)
	while name.value.node <> 0
		if xmlAttribute$(xmlGetFirstChild(name.value.node), "name") = i.name then
			return(true)
		endif
		name.value.node = xmlGetRightSibling(name.value.node)
	endwhile
	return(false)
}

function long SJEquipmentInstallDismantleBOD.add.custom.output.if.any(
		long		i.component.node)
{
	long	additional.elements.xml
	long	index.value.xml
	long	customer.data.location.node
	long	retl

	is.outbound = true
	additional.elements.xml = 0
	index.value.xml = 0
	retl = get.additional.elements(
			"SJEquipmentInstallDismantleBOD",
			additional.elements.xml)
	if retl = DALHOOKERROR then
		return(DALHOOKERROR)
	endif
	if retl = 0 and xmlGetFirstChild(additional.elements.xml) <> 0 then
		customer.data.location.node = xmlFindFirstMatch("<>.<UserArea>",
						i.component.node)
		if customer.data.location.node <> 0 then
			| check if all additional elements are already present in customer data
			if are.all.present(additional.elements.xml, customer.data.location.node) then
				retl = xmlDelete(additional.elements.xml)
				additional.elements.xml = 0
				return(0) | OK
			endif
		endif
		RETIFNOK(txcom.bl952st00.get.SJEquipmentInstallDismantleBOD._index1(
			index.value.xml))
		if customer.data.location.node = 0 then
			retl = createGroupNodes(i.component.node,
						"<UserArea>", "")
			customer.data.location.node = xmlFindFirstMatch("<>.<UserArea>",
							i.component.node)
		endif
		if customer.data.location.node = 0 then
			dal.set.error.message("@No user area (%s-%d)",
					__FILE__, __LINE__)
			return(DALHOOKERROR)
		endif
		RETIFNOK(add.custom.output(
				additional.elements.xml,
				index.value.xml,
				customer.data.location.node))
		if xmlGetFirstChild(customer.data.location.node) = 0 then
			| nothing in UserArea: remove that node 
			retl = xmlDelete(customer.data.location.node)
			customer.data.location.node = 0
		endif
	endif

	retl = xmlDelete(additional.elements.xml)
	additional.elements.xml = 0
	retl = xmlDelete(index.value.xml)
	index.value.xml = 0
	return(0) | OK
}

#define DALERROR_IF(cond, mesg)
^	if cond then
^		dal.set.error.message("@" & mesg)
^		return(DALHOOKERROR)
^	endif

| External function to arrange custom output from On Execute Hook
| Note: This function should be invoked dynamically to prevent a dependency cycle
| (sb -> st-> (hook library) -> sb).
function extern long txcom.bl952sb00.SJEquipmentInstallDismantleBOD.add.custom.output.if.any(
	ref	long	io.user.area.node, | node <UserArea> or 0
	...) | attributes in name-value pairs, the name must be the table column
	     | code (e.g. tcibd001.item).
{
	string	table.column.name(18)
	string	dums(1)
	long	additional.elements.xml
	long	index.value.xml
	long	table.node
	long	column.node
	long	retl
	long	duml
	long	typ
	long	i

	if not exists.customization() then
		| nothing to do
		return(0) | OK
	endif
	
	if io.user.area.node = 0 then
		io.user.area.node = xmlNewNode("UserArea")
		DALERROR_IF(io.user.area.node = 0, "Cannot create XML node")
	endif
	index.value.xml = xmlNewNode("IndexValues")
	DALERROR_IF(index.value.xml = 0, "Cannot create XML node")

	| fill IndexValues based on provided name-value pairs
	for i = 2 to get.argc() step 2
		table.column.name = get.string.arg(i)
		table.node = xmlNewNode("Table", XML_ELEMENT, index.value.xml)
		DALERROR_IF(table.node = 0, "Cannot create XML node")
		retl = xmlSetAttribute(table.node, "name", table.column.name(1;8))
		DALERROR_IF(retl = 0, "Cannot set XML attribute")
		column.node = xmlNewDataElement("Column",
			get.string.arg(i+1), table.node)
		DALERROR_IF(column.node = 0, "Cannot create XML node")
		retl = xmlSetAttribute(column.node, "name", strip$(table.column.name(10)))
		DALERROR_IF(retl = 0, "Cannot set XML attribute")
		retl = rdi.column(table.column.name, dums, duml, duml, duml, typ, duml, dums)
		DALERROR_IF(retl <> 0, "Cannot determine domain for column " & table.column.name)
		if typ = DB.STRING then
			retl = xmlSetAttribute(column.node, "dataType", "DB.STRING")
		else
			retl = xmlSetAttribute(column.node, "dataType", typ)
		endif
		DALERROR_IF(retl = 0, "Cannot set XML attribute")
	endfor
	txcom.bl952st00.set.SJEquipmentInstallDismantleBOD.custom.index(index.value.xml)

	is.outbound = true
	retl = get.additional.elements(
			"SJEquipmentInstallDismantleBOD",
			additional.elements.xml)
	txcom.bl952st00.reset.SJEquipmentInstallDismantleBOD.custom.index()
	if retl = DALHOOKERROR then
		retl = xmlDelete(additional.elements.xml)
		additional.elements.xml = 0
		retl = xmlDelete(index.value.xml)
		index.value.xml = 0
		return(DALHOOKERROR)
	endif
	if retl = 0 and xmlGetFirstChild(additional.elements.xml) <> 0 then
		RETIFNOK(add.custom.output(
				additional.elements.xml,
				index.value.xml,
				io.user.area.node))
		if xmlGetFirstChild(io.user.area.node) = 0 then
			| nothing in UserArea: remove that node 
			retl = xmlDelete(io.user.area.node)
			io.user.area.node = 0
		endif
	endif

	retl = xmlDelete(additional.elements.xml)
	additional.elements.xml = 0
	retl = xmlDelete(index.value.xml)
	index.value.xml = 0
	return(0) | OK
}


long	bl.customization.dll.id
long	bl.customization.function.id

function boolean exists.customization()
{
	static	boolean	initialized
	string	dll.name(15)
	long	dll.id
	long	function.id
	long	retl
	long	retval
	
	if not initialized then
		bl.customization.dll.id = 0
		| Try to load extension DLL
		dll.id = load_dll("otlbctdll1000")
		function.id = get_function(dll.id, "tlbct.dll1000.load.extension.dll")
		retl = exec_function(dll.id, function.id, retval,
				"SJEquipmentInstallDismantleBOD", true, dll.name)
		if retl = 0 and retval = 0 then
			bl.customization.dll.id = load_dll(dll.name)
		endif
		if bl.customization.dll.id > 0 then
			bl.customization.function.id = get_function(
					bl.customization.dll.id,
					"get.additional.elements")
		else
			| load customization library
			bl.customization.dll.id = load_dll("otxcombl952cc00", DLL_SILENT_ERR)
			if bl.customization.dll.id > 0 then
				bl.customization.function.id = get_function(
					bl.customization.dll.id,
					"txcom.bl952cc00.get.additional.elements")
			endif
		endif
		initialized = true
	endif
	
	return(bl.customization.dll.id > 0 and bl.customization.function.id > 0)
}

function long get.additional.elements(
	const	string	i.component.name,
	ref	long	o.additional.elements.xml)
{
	long	retl
	long	retvalue
	
	| Call txcom.bl952cc00.get.additional.elements dynamically.
	if not exists.customization() then
		return(-1)
	endif
	export("is.outbound", is.outbound)
	retl = exec_function(bl.customization.dll.id,
			bl.customization.function.id,
			retvalue,
			i.component.name,
			o.additional.elements.xml)
	if retl <> 0 then
		return(retl)
	endif
	return(retvalue)
}

function long add.custom.output(
		long	i.additional.elements.xml,
		long	i.index.value.xml,
		long	i.customer.data.location.node)
{
	long	retl
	long	retvalue
	
	| Call tlbct.dll1000.add.custom.output dynamically to avoid a fatal
	| error if no recent version of tlbctdll1000 is used.
	retl = exec_dll_function("otlbctdll1000",
					"tlbct.dll1000.add.custom.output",
					retvalue,
					i.additional.elements.xml,
					i.index.value.xml,
					i.customer.data.location.node)
	if retl <> 0 then
		return(retl)
	endif
	return(retvalue)
}

