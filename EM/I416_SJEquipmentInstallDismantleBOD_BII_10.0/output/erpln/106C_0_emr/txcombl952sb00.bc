	l.BreakdownStatus = ltoe(enum.long)
	RETIFNOK(tlbct.dll1000.domain.check.value(i.value,
		"tscfg.pb.stat", "tscfg.pb.stat", "BreakdownStatus"))
	RETIFNOK(txcom.bl952st00.set.SJEquipmentInstallDismantleBOD.BreakdownStatus(
			l.BreakdownStatus))
