function build.selectionnode.for.public.attributes(ref xmlNode io.node)
{
	xmlNode	sel.node

	if io.node = 0 then
		io.node = xmlNewNode(SELECTION)
	endif

	sel.node = xmlNewDataElement(SEL_ATTR,
		"SJEquipmentInstallDismantleBOD.*" , io.node)
}

	     

