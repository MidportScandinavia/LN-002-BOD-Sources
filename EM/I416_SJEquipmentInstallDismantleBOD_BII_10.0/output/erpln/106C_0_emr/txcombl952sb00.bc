|*************************** External Hidden Methods *******************************
function extern long txcom.bl952sb00.SupportsReferentialIntegrity(
					const xmlnode i.RequestArgument,
					ref xmlnode o.ResponseArgument,
					ref xmlnode o.ResultArgument)
{
	DllUsage
	The SupportsReferentialIntegrity function returns information about
	whether the BDE supports the CreateRef and DeleteRef methods.
	Note that the request for this method does not contain any elements.
	Therefore it is not required to read the RequestArgument.
	However, to keep this function similar to the other methods, the same
	function interface has been adopted.
	EndDllUsage

	long	ret
	long	ControlArea
	boolean	ReferentialIntegrityIsSupported

	CHECK_TOOLS_VERSION(o.ResponseArgument, o.ResultArgument)
	
	|* The response consist of a ControlArea and a "supported" element which
	|* contains either a false or a true value.
	RETIFNOK2(createResultObject(o.ResultArgument))
	RETIFNOK2(createResponseObject.WithoutDataArea(
			o.ResponseArgument,
			"SupportsReferentialIntegrity"))

	|* Create a ControlArea to hold the "supported" element
	NEW.NODE("ControlArea", o.ResponseArgument, ControlArea)

	|* Determine whether referential integrity is supported by calling the
	|* appropriate protected method.
	ReferentialIntegrityIsSupported =
		txcom.bl952st00.supports.referential.integrity()

	|* Store the information in the "supported" element
	ret = xmlRewriteDataElement(ControlArea,
			"supported",
			ReferentialIntegrityIsSupported ? "true" : "false")

	|* When this point is reached, no errosrs have been encountered
	|* and the result can be cleared.
	ret = xmlDelete(o.ResultArgument)
	o.ResultArgument = 0
	return(0)	| All went well
}

|*************************** List/Show Methods *******************************

function extern long txcom.bl952sb00.Show(
					const xmlnode i.RequestArgument,
					ref xmlnode o.ResponseArgument,
					ref xmlnode o.ResultArgument)
{
	DllUsage
		This method will show -a part- one Business Object as
		requested in the XML Request message.
		Data from the requested object and warnings will be placed in
		the XML response message.
		Errors are put in the XML result message.
	EndDllUsage
	xmlnode	ControlAreaNode
	string  Value(1024)
	string	origProcessingScope(26)
	boolean	TagFound
	long	retval, ret
	long	sv.time, exec.time

	CHECK_TOOLS_VERSION(o.ResponseArgument, o.ResultArgument)
	
	|* redirect to actual List/Show
	|* Get prefetchConsistentSet (as prepared set) from
	|* the ControlAreaNode Node
	|* Select the ControlArea Node
	ControlAreaNode = xmlFindFirst("ControlArea", i.RequestArgument)
	Value = ""
	RETIFNOK(getValue(ControlAreaNode, 
				"ControlArea.LogQuery",
				"<ControlArea>.<LogQuery>",
				false, Value, TagFound))
				
	if tolower$(strip$(Value)) = "true" or strip$(Value) = "1" then
		log.query = true
	else
		log.query = false
	endif
	Value = ""

	origProcessingScope = bl.processingScope
	sv.time = mtime()
	retval = (txcom.bl952sb00.Show_new(
				i.RequestArgument,
				o.ResponseArgument,
				o.ResultArgument))
	exec.time = mtime() - sv.time
	bl.processingScope = origProcessingScope
	txcom.bl952st00.setProcessingScope(bl.processingScope)
	Value = ""
	RETIFNOK(getValue(ControlAreaNode, 
				"ControlArea.ShowExecuteTime",
				"<ControlArea>.<ShowExecuteTime>",
				false, Value, TagFound))
				
	if (tolower$(strip$(Value)) = "true" or strip$(Value) = "1") and o.ResponseArgument <> 0 then
		ret = xmlsetAttribute(o.ResponseArgument, "ExecuteTime", str$(exec.time))
	endif

	return (retval)
}
 
function xmlNode Show.getMetaDataForFilter()
{
	xmlNode	FilterMetaData
	xmlNode	componentNode
	long	duml
	
	FilterMetaData = xmlNewNode("MetaData", XML_ELEMENT)
	
	componentNode = xmlNewNode("Component", XML_ELEMENT, FilterMetaData)
	duml = xmlSetAttribute(componentNode, "name", strip$("SJEquipmentInstallDismantleBOD"))
	duml = xmlSetAttribute(componentNode, "parent", strip$(""))
	SJEquipmentInstallDismantleBOD.Show.addMetaDataForFilter(componentNode)
	
	return(FilterMetaData)
}

