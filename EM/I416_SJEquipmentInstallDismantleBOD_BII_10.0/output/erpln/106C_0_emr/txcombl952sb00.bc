				SJEquipmentInstallDismantleBOD.Note.select = true
				break
			case "SJEquipmentInstallDismantleBOD.UserArea":
				SJEquipmentInstallDismantleBOD.UserArea.select = true
				break
			case "SJEquipmentInstallDismantleBOD.WorkOrderID":
				SJEquipmentInstallDismantleBOD.WorkOrderID.select = true
				break
			default:			
				break
			endcase
			filter.attribute = xmlGetRightSibling(filter.attribute)
		endwhile
	endif

	return(0)
}

	     
function long txcom.bl952sb00.Show_new(
					const xmlnode i.RequestArgument,
					ref xmlnode o.ResponseArgument,
					ref xmlnode o.ResultArgument)
{
	xmlNode	ResponseSJEquipmentInstallDismantleBODNode
