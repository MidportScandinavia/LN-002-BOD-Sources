				break
			case "SJEquipmentInstallDismantleBOD.FunctionalLocationID":
				SJEquipmentInstallDismantleBOD.FunctionalLocationID.select = true
				break
			case "SJEquipmentInstallDismantleBOD.SuperiorEquipmentID":
				SJEquipmentInstallDismantleBOD.SuperiorEquipmentID.select = true
				break
			case "SJEquipmentInstallDismantleBOD.Item":
				SJEquipmentInstallDismantleBOD.Item.select = true
