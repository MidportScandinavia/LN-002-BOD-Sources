function extern long txcom.bl952sb00.GetIdentifierName(
	ref	string	o.name)
{
DllUsage
	This function must only be used by the Tools Add-On package.
	Do not use it in hook code or other libraries.
	Output: The identifier name (for addition of the variation ID).
	Return value: 0 (OK) or an error value.
EndDllUsage

	o.name = "<BODID>.<ExternalReferenceID>"
	return(0) | OK
}

|------------ GetPublicIdentifiers() for SJEquipmentInstallDismantleBOD ------------

function extern long txcom.bl952sb00.SJEquipmentInstallDismantleBOD.GetPublicIdentifiers(
		ref		long		o.externalData)
{
DllUsage
	This function must only be used by the Tools Add-On package.
	Do not use it in hook code or other libraries.
	Precondition: internal identifiers have been set in the protected layer.
	Return value: 0 (OK) or an error value.
	In case of error a dal error message has been set.
EndDllUsage

#define ERR_IF(condition, component)
^		if condition then
^			dal.set.error.message("tlbctstgen", "PublishEvent", component, "SJEquipmentInstallDismantleBOD")
^			|* Error occurred in Method '%1$s' on component '%2$s' of Object '%3$s'.
^			return(DALHOOKERROR)
^		endif
#define ERR_IF(condition)	ERR_IF(condition, "")

	long	componentNode	| component instance node
	long	retl			| return value to be checked


	retl = handle.output.SJEquipmentInstallDismantleBOD.identifiers(0, componentNode)
	ERR_IF(retl <> 0)
	o.externalData = componentNode
	
	return(0) | OK
}

function long handle.output.SJEquipmentInstallDismantleBOD.identifiers(
					xmlNode i.Node,
			ref   	xmlNode o.Node)
{
| i.Node is parentNode
| o.Node is current component Node (is child of i.Node)
	string  value(1024) mb
	boolean	value.isSet
	xmlNode	g.Node

	| Create component node for SJEquipmentInstallDismantleBOD
	NEW.NODE("SJEquipmentInstallDismantleBOD", i.Node, o.Node)

	g.node = 0
	value = ""
	value.isSet = false
	SJEquipmentInstallDismantleBOD.BODID_ExternalReferenceID.select = true
	g.Node = createGroupNodes(o.Node, "<BODID>.<ExternalReferenceID>", "ExternalReferenceID")
	ASSIGNVAL(SJEquipmentInstallDismantleBOD, BODID_ExternalReferenceID, ExternalReferenceID)
	return(0)
}


	     
	     
