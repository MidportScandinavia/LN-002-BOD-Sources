}

function extern 
long txcom.bl952st00.get.SJEquipmentInstallDismantleBOD._index1(
		ref		long		o.xml)
{
	DllUsage
	EndDllUsage

	long	table.node
	long	column.node
	long	retl
	long	i

	if bl.index.SJEquipmentInstallDismantleBOD <> 0 and
	   xmlGetFirstChild(bl.index.SJEquipmentInstallDismantleBOD) <> 0
	then
		| identifiers already set
		o.xml = xmlDuplicate(bl.index.SJEquipmentInstallDismantleBOD)
		return(0)
	endif
	
	i = 0
	retl = 0
	table.node = 0
	column.node = 0
	o.xml = xmlNewNode("IndexValues")
	DALERROR_IF(o.xml = 0, "Cannot create XML node")

	if column.tscfg200.item.exists() then
		if bl.SJEquipmentInstallDismantleBOD.Item.set then
			table.node = xmlNewNode("Table", XML_ELEMENT, o.xml)
			DALERROR_IF(table.node = 0, "Cannot create XML node")
			retl = xmlSetAttribute(table.node, "name", "tscfg200")
			DALERROR_IF(retl = 0, "Cannot set XML attribute")
			column.node = xmlNewDataElement("Column",
				bl.SJEquipmentInstallDismantleBOD.Item, table.node)
			DALERROR_IF(column.node = 0, "Cannot create XML node")
			retl = xmlSetAttribute(column.node, "name", "item")
			DALERROR_IF(retl = 0, "Cannot set XML attribute")
			retl = xmlSetAttribute(column.node, "dataType", "DB.STRING")
			DALERROR_IF(retl = 0, "Cannot set XML attribute")
		else
			dal.set.error.message("@Protected attribute SJEquipmentInstallDismantleBOD.Item is mandatory.")
			return(DALHOOKERROR)
		endif
	endif
	if column.tscfg200.sern.exists() then
		if bl.SJEquipmentInstallDismantleBOD.SerialNumber.set then
			table.node = xmlNewNode("Table", XML_ELEMENT, o.xml)
			DALERROR_IF(table.node = 0, "Cannot create XML node")
			retl = xmlSetAttribute(table.node, "name", "tscfg200")
			DALERROR_IF(retl = 0, "Cannot set XML attribute")
			column.node = xmlNewDataElement("Column",
				bl.SJEquipmentInstallDismantleBOD.SerialNumber, table.node)
			DALERROR_IF(column.node = 0, "Cannot create XML node")
			retl = xmlSetAttribute(column.node, "name", "sern")
			DALERROR_IF(retl = 0, "Cannot set XML attribute")
			retl = xmlSetAttribute(column.node, "dataType", "DB.STRING")
			DALERROR_IF(retl = 0, "Cannot set XML attribute")
		else
			dal.set.error.message("@Protected attribute SJEquipmentInstallDismantleBOD.SerialNumber is mandatory.")
			return(DALHOOKERROR)
		endif
	endif
	return(0)
}


|****************************** Helper functions for control data **********

function boolean getControlAttribute(
	const	string	i.name,
	ref	string	o.value)
{
	return(getControlAttributeFromRequest(
		bl.RequestArgument, i.name, o.value))
}

function boolean setControlAttribute(
	const	string	i.name,
	const	string	i.value)
{
	return(setControlAttributeInResponse(
		bl.ResponseArgument, i.name, i.value))
}

function boolean getControlAttributeFromRequest(
		long	i.request,
	const	string	i.name,
	ref	string	o.value)
{
	xmlnode ControlAreaNode
	long	retl

	ControlAreaNode = xmlFindFirst("ControlArea", i.request)
	retl = xmlGetDataElement(ControlAreaNode, i.name, o.value)
	if retl = 0 then
		return (false)
	endif
	return (true)
}

function boolean setControlAttributeInResponse(
		long	io.response,
	const	string	i.name,
	const	string	i.value)
{
	xmlnode ControlAreaNode
	long	retl

	ControlAreaNode = xmlFindFirst("ControlArea", io.response)
	if ControlAreaNode = 0 then
		ControlAreaNode = xmlNewNode("ControlArea")
		retl = xmlInsertInChilds(io.response, ControlAreaNode)
		if retl = 0 then
			return (false)
		endif
	endif
	retl = xmlRewriteDataElement(ControlAreaNode, i.name, i.value)
	if retl = 0 then
		return (false)
	endif
	return (true)
}

function boolean getAttributeValueFromRequest(
		long	i.request,
	const	string	i.path,
	ref	string	o.value)
{
	string	path(1000)
	long	matching.node

	path = i.path
	if isspace(i.path) or not tlbct.dll1000.replace.data(path, ".", ">.<") then
		o.value = ""
		return(false)
	endif
	matching.node = xmlFindFirstMatch(sprintf$("<>.<DataArea>.<%s>", path),
					i.request)
	if matching.node = 0 or xmlGetType(xmlGetFirstChild(matching.node)) <> XML_DATA then
		o.value = ""
		return(false)
	endif
	o.value = xmlData$(matching.node)
	return(true)
}

function long getRequest()
{
	return(bl.RequestArgument)
}

#define attributeIsSelected(componentName, attributeImplementationName)
^	bl.##componentName##.##attributeImplementationName##.selected

function do.not.use.this.function()
{
| The purpose of this function is to avoid compile warnings on unused
| functions.
	
	boolean	dumb
	long	duml
	string	dums(1)
	
	if false then
		do.not.use.this.function()
		dumb = getControlAttribute(dums, dums)
		dumb = setControlAttribute(dums, dums)
		dumb = getControlAttributeFromRequest(duml, dums, dums)
		dumb = setControlAttributeInResponse(duml, dums, dums)
		dumb = getAttributeValueFromRequest(duml, dums, dums)
		duml = getRequest()
		duml = handle.result(duml)
		duml = OCM_SET_QUERY_MODE("")
		duml = txcom.bl952st00.SJEquipmentInstallDismantleBOD.Show.set.derived()
		log.identifiers.DAL.message.SJEquipmentInstallDismantleBOD()
		dums = childComponentJoin.SJEquipmentInstallDismantleBOD("")
		dums = nonRootJoin.SJEquipmentInstallDismantleBOD.tscfg200_1()
	endif
}



