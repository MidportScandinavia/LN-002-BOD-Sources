	long	ret

	if bl.sql.pointer.SJEquipmentInstallDismantleBOD <> 0 then
		ret = sql.fetch(bl.sql.pointer.SJEquipmentInstallDismantleBOD)
	else
		ret = ENOREC
	endif
	on case ret
	case 0:
