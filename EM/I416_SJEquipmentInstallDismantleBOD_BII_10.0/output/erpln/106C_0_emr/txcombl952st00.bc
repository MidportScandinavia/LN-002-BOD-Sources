function extern boolean txcom.bl952st00.is.business.studio.supported()
{
	| Checks if the needed functionality is present.
	static	boolean	initialized
	static	boolean	supported
	long		dll.id
	
	if not initialized then
		if get.tools.tiv() < 1400 then
			| A check is done if DLL tlbctdll1000 has external function
			| tlbct.dll1000.remove.nillable.attributes().
			dll.id = load_dll("otlbctdll1000", DLL_SILENT_ERR)
			if dll.id = 0 then
				supported = false
			else
				supported = (get_function(dll.id, "tlbct.dll1000.remove.nillable.attributes") > 0)
			endif
		else
			| ES 8.4.2 or later is used
			supported = true
		endif
		initialized = true
	endif
	return(supported)
}

function long column.exists(
	const	string	i.table,
	const	string	i.column)
{
| Returns:
| > 0: the depth of the column (1 for non-array columns)
|   0: column (or table) does not exist

static	long	tables
	long	table.node
	long	fp
	long	duml
	long	retl
	long	nr.keys
	long	nr.columns
	long	i
	string	column.name(17)
	string	dums
	long	depth
	long	column.type
	long	column.offset
	long	table.real.length

	if tables = 0 then
		| initialize structure
		tables = xmlNewNode("tables")
	endif
	table.node = xmlFindFirst(i.table, tables)
	if table.node = 0 then
		| initialize node for table
		table.node = xmlNewNode(i.table, XML_ELEMENT, tables)
		
		if get.bshell.tiv() < 2100 then
			| check if table exists
			fp = seq.open("{nolog}F_BRDD:d" & i.table, "r")
			if fp > 0 then
				| table exists
				duml = seq.close(fp)
			else
				| table does not exist
				return(0)
			endif
		endif
		
		retl = rdi.table(i.table, nr.keys, nr.columns, duml, table.real.length)
		if retl = 0 then
			| add the columns to the table node
			for i = 1 to nr.columns
				retl = rdi.table.column(i.table, i,
					column.name, dums, column.offset, duml,
					depth, column.type, duml, dums)
				if retl = 0 and
				   is.application.column(column.name, column.type, column.offset, table.real.length) then
					duml = xmlSetAttribute(table.node, column.name(10), depth)
				endif
			endfor
		endif
	endif
	
	| retrieve depth from structure
	depth = lval(xmlAttribute$(table.node, i.column))
	
	return(depth)
}

function boolean is.application.column(const string i.column.name, long i.column.type, long i.column.offset, long i.table.real.length)
{
#if ES_TIV_LEVEL >= 2032
	if get.tools.tiv() >= 2032 then
		return(rdi.is.application.column(i.column.name, i.column.type, i.column.offset, i.table.real.length))
	else
#endif
		| Any column starting at the real length is not an application column
		if i.column.offset >= i.table.real.length then
			return(false)
		endif
	
		| Indices and combined fields are not considered application columns
		if i.column.type = DB.COMBINED then
			return(false)
		endif
	
		| Reference counters and rcd_utc are the only columns that are automatically added before the real length
		if i.column.name(10;7) = "Refcntd" or
		   i.column.name(10;7) = "Refcntu" or
		   i.column.name(10;7) = "rcd_utc" then
			return(false)
		endif

		return(true)
#if ES_TIV_LEVEL >= 2032
	endif
#endif
}


function boolean column.tscfg200.cdf_giai.exists()
{
	static	boolean	initialized	| whether this method was called before
	static	boolean	exists		| whether the column exists in the current application version
			long	depth	| depth for array column
	
	if not initialized then
		depth = column.exists("tscfg200", "cdf_giai")
		exists = (depth > 0)

		initialized = true
	endif
	return(exists)
}

function boolean column.tscfg200.cdf_giai.changed(const string i.value)
{
	string	value(100) mb	| current value of field
	long	retl	| return value to be checked
	
	retl = get.var(pid, "tscfg200.cdf_giai", value)
	if retl <> 1 then
		return(false)
	endif
	return(strip$(value) <> strip$(i.value))
}

