|****************************** Setting fields for create/change *************

|****************************** Set derived attributes ***********************

| The following function is used by any non-batch method implementation.
| So either standard methods such as Create/Change/Delete or List/Show or
| specific methods.

function 
long txcom.bl952st00.SJEquipmentInstallDismantleBOD.Show.set.derived()
{
	FunctionUsage
	This function is be called after setting the public input arguments for a method,
	before starting the actual execution.
	In other words, at the start of the before.execute... function.
	It sets the protected/private attribute implementations that are derived from the
	public input arguments.
	For example, public attributes A1, A2, A3 and A4 exist.
	Protected attributes having on set hooks are P1 (used attribute A2),
	P2 (used attribute P1), P3 (used attributes A2 and P4),
	P4 (used attributes P2 and A3) and P5 (no used attributes).
	Then the following logic is executed (sequence must take dependencies into account!):
	- set P5
	- If A2 is set then set P1
	- If P1 is set then set P2
	- If P2 is set or(!) A3 is set then set P4
	- If A2 is set or(!) P4 is set then set P3
	EndFunctionUsage
	long	i

	i = 0
	return(0) | OK
}

|***************************** Private Functions ******************************

function clear.recent.DAL.error.messages()
{
	long	ret.bl
	string  MessageCode(25)
	string  MessageContent(256) mb
	long    MessageTypeCode

	while dal.count.messages(MSG.ALL) > bl.dal.nr.messages
		ret.bl = dal.get.last.message(MSG.ALL, MessageCode,
			MessageContent,
		   MessageTypeCode)
	endwhile
}

function set.current.number.of.DAL.messages()
{
	bl.dal.nr.messages = dal.count.messages(MSG.ALL)
}

function log.identifiers.DAL.message.SJEquipmentInstallDismantleBOD()
{
	| Because the application DAL does not always log all identifiers,
	| it would be difficult to determine which instance causes the
	| reported problem. Therefore, the identifiers are logged in this
	| function.
	dal.set.error.message("@Identifiers: BODID_ExternalReferenceID=" &
			trim$(bl.SJEquipmentInstallDismantleBOD.BODID_ExternalReferenceID)
	)
}

function long handle.result(long i.result)
{

	string	e.message(256) mb
	string	mscode(12)

	if i.result = 0 then
		return (0)
	endif
	if i.result = 0 or
	   i.result = DALHOOKERROR or
	   i.result = DALDBERROR or
	   i.result = DALNOSETPERM or
	   i.result = DALNOOBJPERM then
		|* error message already present
		if i.result <> 0 then
			dal.set.info.message("tlbctstgen",
				strip$(bl.method), strip$(bl.component),
				strip$(bl.bodesc))
			|* Error occurred in Method '%1$s' on component '2$s'
			|* of Object '%3$s'
		endif
		return(i.result)
	endif

	e.message = ""
	if i.result > 0 then
		|* get errormessage by messcode tlbcterrX
		mscode = "tlbcterr" & str$(i.result)
		e.message = sprintf$(form.text$(mscode),
					strip$(bl.method), strip$(bl.object))
	endif

	if i.result > 0 and pos(e.message, "???") = 0 then
		dal.set.error.message(mscode,
				bl.method, strip$(bl.object))
	else
		e.message = db.error.message()
		if isspace(e.message) then
			dal.set.error.message("tlbcts0021",
						strip$(bl.method),
						strip$(bl.object),
						i.result)
			|* Method '%1$s', Object '%2$s':
			|* error-code: %3$d ( Error description not present )
			tlbct.dll1000.log(__FILE__, __LINE__,
				sprintf$(form.text$("tlbcts0004"),
	 						i.result))
			|* Error description not present (code: %1$d).
		else
			dal.set.error.message("@" & e.message)
			dal.set.info.message("tlbctstgen",
				strip$(bl.method), strip$(bl.component),
				strip$(bl.bodesc))
			|* Error occurred in Method '%1$s' on component '2$s'
			|* of Object '%3$s'
		endif
	endif
	return(i.result)
}

