#context_on "HOOK:onGetHook; ATTRIBUTE:SJEquipmentInstallDismantleBOD.StorageLocation"
function long Hook.OnGet.SJEquipmentInstallDismantleBOD.StorageLocation(
		domain	tcitem	i.Item,
		boolean			i.Item.isSet,
		domain	tcibd.sern	i.SerialNumber,
		boolean			i.SerialNumber.isSet,
	ref domain	tcmcs.st10m	o.StorageLocation,
	ref boolean	io.StorageLocation.isSet)
{
io.StorageLocation.isSet = true

	o.StorageLocation = ""
	select	tscfg210.*
	from	tscfg210
	where	tscfg210._index2 = {:i.Item,:i.SerialNumber}
	and   	tscfg210.cdf_dism = {"Dismantle"}
	order by tscfg210.sttm desc
	as set with 1 rows
	selectdo
	|	select	tssoc220.awrh, tssoc220.lino
		select	tssoc220.*
		from	tssoc220
		where	tssoc220.orno = {:tscfg210.cdf_orno}
		and	tssoc220.acln = {:tscfg210.cdf_acln}
		and	tssoc220.item = {:i.Item}
		and	tssoc220.sern = {:i.SerialNumber}
		as set with 1 rows
		selectdo
		endselect
		bl.SJEquipmentInstallDismantleBOD.Lot = str$(tssoc220.lino)
		if tssoc220.dltp = tsmdm.dltp.to.scrap or tssoc220.dltp = tsmdm.dltp.from.serv.inv then		|#EMSJ_1012_003.sn
			if not isspace(tssoc220.cdf_cwar) then
				select	tsmdm903.*
				from	tsmdm903
				where	tsmdm903.warh.c = {:tssoc220.cdf_cwar}
				as set with 1 rows
				selectdo
				endselect
			endif
		else												|#EMSJ_1012_003.en		
			if not isspace(tssoc220.awrh) then
			|	select	tsmdm903.sjwh.c:o.StorageLocation
				select	tsmdm903.*
				from	tsmdm903
				where	tsmdm903.warh.c = {:tssoc220.awrh}
				as set with 1 rows
				selectdo
			|		o.StorageLocation = tsmdm903.sjwh.c
				endselect
			endif
		endif												|#EMSJ_1012_003.n
		o.StorageLocation = tsmdm903.sjwh.c
	|	endselect
	selectempty
		select	tscfg215.*
		from	tscfg215
		where	tscfg215._index2 = {:i.Item,:i.SerialNumber}
		order by tscfg215.lgtm desc
		as set with 1 rows
		selectdo
		|	select	tssoc220.awrh, tssoc220.lino
			select	tssoc220.*
			from	tssoc220
			where	tssoc220.orno = {:tscfg210.cdf_orno}
			and	tssoc220.acln = {:tscfg210.cdf_acln}
			and	tssoc220.item = {:i.Item}
			and	tssoc220.sern = {:i.SerialNumber}
			as set with 1 rows
			selectdo
			endselect
			bl.SJEquipmentInstallDismantleBOD.Lot = str$(tssoc220.lino)
			if tssoc220.dltp = tsmdm.dltp.to.scrap or tssoc220.dltp = tsmdm.dltp.from.serv.inv then		|#EMSJ_1012_003.sn
			if not isspace(tssoc220.cdf_cwar) then
				select	tsmdm903.*
				from	tsmdm903
				where	tsmdm903.warh.c = {:tssoc220.cdf_cwar}
				as set with 1 rows
				selectdo
				endselect
			endif
			else												|#EMSJ_1012_003.en
				if not isspace(tssoc220.awrh) then
				|	select	tsmdm903.sjwh.c:o.StorageLocation
					select	tsmdm903.*
					from	tsmdm903
					where	tsmdm903.warh.c = {:tssoc220.awrh}
					as set with 1 rows
					selectdo
				|	o.StorageLocation = tsmdm903.sjwh.c
					endselect
				endif
			endif												|#EMSJ_1012_003.n
			o.StorageLocation = tsmdm903.sjwh.c
		|	endselect
		endselect
		
		if ((tscfg215.cdf_serv = 1 or tscfg215.cdf_serv = 2) and etol(tscfg215.stat) = 20) or install_publish = "9" then 
			select	tscfg215.*
			from	tscfg215
			where	tscfg215._index2 = {:i.Item,:i.SerialNumber}
			and	tscfg215.stat = 10
			order by tscfg215.lgtm desc
			as set with 1 rows
			selectdo
			|	select	tssoc220.awrh, tssoc220.lino 
				select	tssoc220.*
				from	tssoc220
				where	tssoc220.orno = {:tscfg210.cdf_orno}
				and	tssoc220.acln = {:tscfg210.cdf_acln}
				and	tssoc220.item = {:i.Item}
				and	tssoc220.sern = {:i.SerialNumber}
				as set with 1 rows
				selectdo
				endselect
				bl.SJEquipmentInstallDismantleBOD.Lot = str$(tssoc220.lino)
				if tssoc220.dltp = tsmdm.dltp.to.scrap or tssoc220.dltp = tsmdm.dltp.from.serv.inv then		|#EMSJ_1012_003.sn
					if not isspace(tssoc220.cdf_cwar) then
						select	tsmdm903.*
						from	tsmdm903
						where	tsmdm903.warh.c = {:tssoc220.cdf_cwar}
						as set with 1 rows
						selectdo
						endselect
					endif
				else												|#EMSJ_1012_003.en
					if not isspace(tssoc220.awrh) then
					|	select	tsmdm903.sjwh.c:o.StorageLocation
						select	tsmdm903.*
						from	tsmdm903
						where	tsmdm903.warh.c = {:tssoc220.awrh}
						as set with 1 rows
						selectdo
					|		o.StorageLocation = tsmdm903.sjwh.c
						endselect
					endif
				endif												|#EMSJ_1012_003.n
				o.StorageLocation = tsmdm903.sjwh.c
			|	endselect
			endselect
		endif
	endselect	
	
	io.StorageLocation.isSet = true
	return(0)
}
#context_off
#context_on "HOOK:onGetHook; ATTRIBUTE:SJEquipmentInstallDismantleBOD.Material"
function long Hook.OnGet.SJEquipmentInstallDismantleBOD.Material(
		domain	tcmcs.str50m	i.EquipmentID,
		boolean			i.EquipmentID.isSet,
		domain	tcmcs.str100m	i.FunctionalLocationID,
		boolean			i.FunctionalLocationID.isSet,
		domain	tcmcs.str7	i.Position,
		boolean			i.Position.isSet,
	ref domain	tcmcs.str100m	o.Material,
	ref boolean	io.Material.isSet)
{
io.Material.isSet = true

	o.Material = ""
	if not isspace(i.FunctionalLocationID) then
		o.Material = concat$("_", trim$(i.FunctionalLocationID), i.Position)
	else
		if not isspace(i.EquipmentID) then
			o.Material = concat$("_", trim$(i.EquipmentID), i.Position)
		endif
	endif
	io.Material.isSet = true
	return(0)
}
#context_off
#context_on "HOOK:onExecuteHook; Method:SJEquipmentInstallDismantleBOD.OnProcess"
function long Hook.OnExecute.SJEquipmentInstallDismantleBOD.OnProcess(
		const		long		i.request,
		ref		long		o.response,
		ref		long		o.result)
{
	ret = txcom.dll9952.handle.incoming.request.for.sj.equipment.install.dismantle.bod(
				i.request, err.msg)

	if ret <> 0 then
		dal.set.error.message("@" & err.msg)
		return(DALHOOKERROR)
	endif
	
	return(0)
}
