#context_off
#context_on "HOOK:afterGetHook; ATTRIBUTE:SJEquipmentInstallDismantleBOD.EquipmentID"
function long Hook.AfterGet.SJEquipmentInstallDismantleBOD.EquipmentID(
		domain	tcitem	i.Item,
		boolean			i.Item.isSet,
		domain	tcibd.sern	i.SerialNumber,
		boolean			i.SerialNumber.isSet,
		domain tcmcs.str50m	i.EquipmentID,
		boolean				i.EquipmentID.isSet)
{
	select	tscfg210.*
	from	tscfg210
	where	tscfg210._index2 = {:i.Item,:i.SerialNumber}
	and   	tscfg210.cdf_dism = {"Dismantle"}
	order by tscfg210.sttm desc
	as set with 1 rows
	selectdo
		bl.SJEquipmentInstallDismantleBOD.BreakdownStatus = tscfg210.stat
		bl.SJEquipmentInstallDismantleBOD.ValidFromDate = tscfg210.sttm
		bl.SJEquipmentInstallDismantleBOD.Position = tscfg210.lcid
		bl.SJEquipmentInstallDismantleBOD.ServiceOrder = tscfg210.cdf_orno
		bl.SJEquipmentInstallDismantleBOD.ActivityNumber = tscfg210.cdf_acln
		bl.SJEquipmentInstallDismantleBOD.VehiclePosition = tscfg210.cdf_cloc		
		bl.SJEquipmentInstallDismantleBOD.SeverityCode = 0
		bl.SJEquipmentInstallDismantleBOD.Note = ""
	|	bl.SJEquipmentInstallDismantleBOD.ResultCode =	str$(tscfg215.cdf_lino)		|#EMSJ_1012_002.n	|#EMSJ_1012_009.o		|* Material Line
		bl.SJEquipmentInstallDismantleBOD.ResultCode = str$(tscfg210.cdf_lino)		|#EMSJ_1012_002.n	|#EMSJ_1012_009.n		|* Material Line
|#EMSJ_1012_004.sn
		if not isspace(tscfg210.pitm) and not isspace(tscfg210.pser) then
			select	tscfg200.cdf_giai, tscfg200.cdf_evne
			from	tscfg200
			where	tscfg200._index1 = {:tscfg210.pitm, :tscfg210.pser}
			as set with 1 rows
			selectdo
				if not isspace(tscfg200.cdf_evne) then
					bl.SJEquipmentInstallDismantleBOD.FunctionalLocationID = tscfg200.cdf_evne
				else
					if not isspace(tscfg200.cdf_giai) then
						bl.SJEquipmentInstallDismantleBOD.SuperiorEquipmentID = tscfg200.cdf_giai
					endif
				endif
			endselect
		endif
|#EMSJ_1012_004.en
|#EMSJ_1012_009.sn
		if not isspace(tscfg210.cdf_orno) and tscfg210.cdf_acln <> 0 then
			select	tssoc210.*
			from	tssoc210
			where	tssoc210._index1 = {:tscfg210.cdf_orno,:tscfg210.cdf_acln}
			as set with 1 rows
			selectdo
			endselect
			bl.SJEquipmentInstallDismantleBOD.WorkOrderID = tssoc210.cdf_word
		endif
|#EMSJ_1012_009.en
	selectempty
		select	tscfg215.*
		from	tscfg215
		where	tscfg215._index2 = {:i.Item,:i.SerialNumber}
		order by tscfg215.lgtm desc
		as set with 1 rows
		selectdo
			bl.SJEquipmentInstallDismantleBOD.BreakdownStatus = tscfg215.stat
			bl.SJEquipmentInstallDismantleBOD.ValidFromDate = tscfg215.ettm
			bl.SJEquipmentInstallDismantleBOD.Position = tscfg215.lcid
			bl.SJEquipmentInstallDismantleBOD.ServiceOrder = tscfg215.cdf_orno
			bl.SJEquipmentInstallDismantleBOD.ActivityNumber = tscfg215.cdf_acln
			bl.SJEquipmentInstallDismantleBOD.SeverityCode = tscfg215.cdf_serv
			bl.SJEquipmentInstallDismantleBOD.Note = tscfg215.cdf_note		
			bl.SJEquipmentInstallDismantleBOD.VehiclePosition = tscfg215.cdf_cloc
			bl.SJEquipmentInstallDismantleBOD.ResultCode = str$(tscfg215.cdf_lino)		|#EMSJ_1012_002.n		|* Material Line		
|#EMSJ_1012_004.sn
			if not isspace(tscfg215.pitm) and not isspace(tscfg215.pser) then
				select	tscfg200.cdf_giai, tscfg200.cdf_evne
				from	tscfg200
				where	tscfg200._index1 = {:tscfg215.pitm, :tscfg215.pser}
				as set with 1 rows
				selectdo
					if not isspace(tscfg200.cdf_evne) then
						bl.SJEquipmentInstallDismantleBOD.FunctionalLocationID = tscfg200.cdf_evne
					else
						if not isspace(tscfg200.cdf_giai) then
							bl.SJEquipmentInstallDismantleBOD.SuperiorEquipmentID = tscfg200.cdf_giai
						endif
					endif
				endselect
			endif
|#EMSJ_1012_004.en
|#EMSJ_1012_009.sn
			if not isspace(tscfg215.cdf_orno) and tscfg215.cdf_acln <> 0 then
				select	tssoc210.*
				from	tssoc210
				where	tssoc210._index1 = {:tscfg215.cdf_orno,:tscfg215.cdf_acln}
				as set with 1 rows
				selectdo
				endselect
				bl.SJEquipmentInstallDismantleBOD.WorkOrderID = tssoc210.cdf_word
			endif
|#EMSJ_1012_009.en
		endselect
		
		if ((tscfg215.cdf_serv = 1 or tscfg215.cdf_serv = 2) and etol(tscfg215.stat) = 20) or install_publish = "9"  then 
			select	tscfg215.*
			from	tscfg215
			where	tscfg215._index2 = {:i.Item,:i.SerialNumber}
			and	tscfg215.stat = 10
			order by tscfg215.lgtm desc
			as set with 1 rows
			selectdo
				bl.SJEquipmentInstallDismantleBOD.BreakdownStatus = tscfg215.stat
				bl.SJEquipmentInstallDismantleBOD.ValidFromDate = tscfg215.ettm
				bl.SJEquipmentInstallDismantleBOD.Position = tscfg215.lcid
				bl.SJEquipmentInstallDismantleBOD.ServiceOrder = tscfg215.cdf_orno
				bl.SJEquipmentInstallDismantleBOD.ActivityNumber = tscfg215.cdf_acln
				bl.SJEquipmentInstallDismantleBOD.SeverityCode = tscfg215.cdf_serv
				bl.SJEquipmentInstallDismantleBOD.Note = tscfg215.cdf_note
				bl.SJEquipmentInstallDismantleBOD.VehiclePosition = tscfg215.cdf_cloc	
				bl.SJEquipmentInstallDismantleBOD.ResultCode = str$(tscfg215.cdf_lino)		|#EMSJ_1012_002.n		|* Material Line	
|#EMSJ_1012_004.sn
				if not isspace(tscfg215.pitm) and not isspace(tscfg215.pser) then
					select	tscfg200.cdf_giai, tscfg200.cdf_evne
					from	tscfg200
					where	tscfg200._index1 = {:tscfg215.pitm, :tscfg215.pser}
					as set with 1 rows
					selectdo
						if not isspace(tscfg200.cdf_evne) then
							bl.SJEquipmentInstallDismantleBOD.FunctionalLocationID = tscfg200.cdf_evne
						else
							if not isspace(tscfg200.cdf_giai) then
								bl.SJEquipmentInstallDismantleBOD.SuperiorEquipmentID = tscfg200.cdf_giai
							endif
						endif
					endselect
				endif
|#EMSJ_1012_004.en		
|#EMSJ_1012_009.sn
				if not isspace(tscfg215.cdf_orno) and tscfg215.cdf_acln <> 0 then
					select	tssoc210.*
					from	tssoc210
					where	tssoc210._index1 = {:tscfg215.cdf_orno,:tscfg215.cdf_acln}
					as set with 1 rows
					selectdo
					endselect
					bl.SJEquipmentInstallDismantleBOD.WorkOrderID = tssoc210.cdf_word
				endif
|#EMSJ_1012_009.en	
			endselect
		endif
	endselect
	
	return(0)
}
